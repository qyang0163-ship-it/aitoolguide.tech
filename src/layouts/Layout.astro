---
interface Props {
	title: string;
	lang?: string;
}

const { title, lang = 'en' } = Astro.props;

const locales = ['en', 'zh-CN', 'zh-TW', 'ja', 'ko', 'es', 'fr', 'de', 'pt', 'ru', 'ar', 'hi', 'th', 'tr', 'vi', 'id'];
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'} id="html-root">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="AIToolGuide - The most practical AI money-making tools directory in 2026. Learn how to use AI tools for side hustles, freelance work, and income growth." />
		<meta name="keywords" content="AI tools,make money with AI,ChatGPT,Midjourney,AI side hustle,AI writing,AI design,freelance" />
		<meta name="author" content="AIToolGuide Team" />
		<meta name="robots" content="index, follow" />
		<meta name="googlebot" content="index, follow" />
		<meta name="bingbot" content="index, follow" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.aitoolguide.tech/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="The most practical AI money-making tools directory in 2026. Learn how to use AI tools for side hustles, freelance work, and income growth." />
		<meta property="og:image" content="https://www.aitoolguide.tech/og-image.jpg" />
		<meta property="og:locale" content={lang.replace('-', '_')} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://www.aitoolguide.tech/" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content="The most practical AI money-making tools directory in 2026. Learn how to use AI tools for side hustles, freelance work, and income growth." />
		<meta property="twitter:image" content="https://www.aitoolguide.tech/og-image.jpg" />
		
		<!-- Canonical URL -->
		<link rel="canonical" href={`https://www.aitoolguide.tech${currentPath}`} />
		
		<!-- Hreflang tags for SEO -->
		{locales.map(locale => (
			<link rel="alternate" hreflang={locale} href={`https://www.aitoolguide.tech/${locale}${currentPath}`} />
		))}
		<link rel="alternate" hreflang="x-default" href={`https://www.aitoolguide.tech${currentPath}`} />
		
		<!-- Structured Data -->
		<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "AIToolGuide",
			"url": "https://www.aitoolguide.tech",
			"description": "The most practical AI money-making tools directory in 2026",
			"potentialAction": {
				"@type": "SearchAction",
				"target": "https://www.aitoolguide.tech/search?q={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		}
		</script>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Google Analytics (GA4) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-14213142037" is:inline></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-14213142037');
			// Track CTA button clicks
			document.addEventListener('click', function(e) {
				var btn = e.target.closest('.btn-urgent, .btn-primary, [data-track]');
				if (btn) {
					var label = btn.textContent.trim().substring(0, 50);
					var page = window.location.pathname;
					var lang = localStorage.getItem('aitg_lang') || 'en';
					gtag('event', 'cta_click', {
						'event_category': 'conversion',
						'event_label': label,
						'page_path': page,
						'user_language': lang
					});
				}
			});
			// Track language switches
			var origSetLang = window.AITG_i18n && window.AITG_i18n.setLang;
			if (origSetLang) {
				var _orig = origSetLang;
				window.AITG_i18n.setLang = function(code) {
					gtag('event', 'language_switch', { 'event_category': 'i18n', 'event_label': code });
					return _orig(code);
				};
			}
		</script>
		<!-- Vercel Analytics -->
		<script defer src="/_vercel/insights/script.js" is:inline></script>
		<style is:global>
			:root {
				--primary: #00d4ff;
				--secondary: #0066ff;
				--accent: #00ff88;
				--dark: #0a0e1a;
				--gray: #8b9bb4;
				--border: #1e3a5f;
				--bg-dark: #050811;
				--bg-card: #0d1526;
				--glow: 0 0 20px rgba(0, 212, 255, 0.3);
			}
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				line-height: 1.6;
				color: #e8f4f8;
				background: var(--bg-dark);
				background-image: 
					radial-gradient(circle at 20% 50%, rgba(0, 102, 255, 0.15) 0%, transparent 50%),
					radial-gradient(circle at 80% 80%, rgba(0, 212, 255, 0.1) 0%, transparent 50%),
					linear-gradient(180deg, var(--bg-dark) 0%, #0a1628 100%);
				min-height: 100vh;
			}
			a {
				text-decoration: none;
				color: inherit;
			}
			.container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 20px;
			}
			.btn {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 14px 28px;
				border-radius: 10px;
				font-weight: 600;
				font-size: 1rem;
				transition: all 0.3s;
				border: none;
				cursor: pointer;
			}
			.btn-primary {
				background: linear-gradient(135deg, var(--primary), var(--secondary));
				color: white;
				box-shadow: 0 4px 14px rgba(0, 212, 255, 0.4), var(--glow);
				border: 1px solid rgba(0, 212, 255, 0.3);
			}
			.btn-primary:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 20px rgba(0, 212, 255, 0.6), 0 0 30px rgba(0, 212, 255, 0.4);
			}
			.btn-secondary {
				background: white;
				color: var(--dark);
				border: 2px solid var(--border);
			}
			.btn-secondary:hover {
				border-color: var(--primary);
				color: var(--primary);
			}
			.btn-urgent {
				background: linear-gradient(135deg, #ef4444, #f97316);
				color: white;
				box-shadow: 0 4px 14px rgba(239, 68, 68, 0.4);
				animation: pulse 2s infinite;
			}
			.btn-urgent:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 20px rgba(239, 68, 68, 0.5);
			}
			@keyframes pulse {
				0%, 100% { transform: scale(1); }
				50% { transform: scale(1.02); }
			}
			.btn-large {
				padding: 18px 36px;
				font-size: 1.125rem;
			}
			.money-badge {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				padding: 6px 12px;
				background: linear-gradient(135deg, #fef3c7, #fde68a);
				color: #92400e;
				font-weight: 700;
				font-size: 0.8rem;
				border-radius: 20px;
			}
			.urgency-banner {
				background: linear-gradient(90deg, #fef3c7, #fee2e2);
				padding: 10px;
				text-align: center;
				font-weight: 600;
				color: #92400e;
				font-size: 0.9rem;
			}
			/* RTL Support for Arabic */
			[dir="rtl"] .nav-links {
				flex-direction: row-reverse;
			}
			[dir="rtl"] .hero-actions,
			[dir="rtl"] .cta-actions,
			[dir="rtl"] .bottom-cta-buttons {
				flex-direction: row-reverse;
			}
			[dir="rtl"] .footer-links {
				flex-direction: row-reverse;
			}
			[dir="rtl"] .article-card-footer,
			[dir="rtl"] .tool-detail-header,
			[dir="rtl"] .method-header {
				flex-direction: row-reverse;
			}
		</style>
	</head>
	<body>
		<!-- Auth Header (Clerk Frontend JS) -->
		<div id="clerk-auth-header" style="position: fixed; top: 0; right: 0; z-index: 9999; padding: 10px 20px; display: flex; gap: 8px; align-items: center;">
		</div>
		<script is:inline>
			// Clerk Frontend-only integration
			(function() {
				const CLERK_PK = 'pk_test_dGVhY2hpbmctZ2FyZmlzaC03NS5jbGVyay5hY2NvdW50cy5kZXYk';
				const script = document.createElement('script');
				script.src = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@latest/dist/clerk.browser.js';
				script.crossOrigin = 'anonymous';
				script.onload = async function() {
					try {
						const clerk = new window.Clerk(CLERK_PK);
						await clerk.load();
						window.__clerk = clerk;
						const header = document.getElementById('clerk-auth-header');
						if (!header) return;
						if (clerk.user) {
							// Signed in - show user button
							const div = document.createElement('div');
							div.id = 'user-button';
							header.appendChild(div);
							clerk.mountUserButton(div);
						} else {
							// Signed out - show sign in button
							const div = document.createElement('div');
							div.id = 'sign-in-btn';
							header.appendChild(div);
							clerk.mountSignIn(div, { appearance: { elements: { rootBox: { display: 'none' } } } });
							const btn = document.createElement('button');
							btn.textContent = 'Sign In';
							btn.style.cssText = 'background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; padding: 8px 18px; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 0.85rem;';
							btn.onclick = () => clerk.openSignIn();
							header.appendChild(btn);
						}
					} catch(e) {
						console.log('Clerk init skipped:', e.message);
					}
				};
				document.head.appendChild(script);
			})();
		</script>
		<slot />
		<script src="/i18n.js" is:inline></script>
		<script>
			// Immediate language detection to prevent flash of wrong language
			(function() {
				const savedLang = localStorage.getItem('aitg_lang');
				if (savedLang) {
					document.documentElement.lang = savedLang === 'zh-CN' ? 'zh-Hans' : savedLang === 'zh-TW' ? 'zh-Hant' : savedLang;
					if (savedLang === 'ar') {
						document.documentElement.dir = 'rtl';
					}
				}
			})();
		</script>
	</body>
</html>
