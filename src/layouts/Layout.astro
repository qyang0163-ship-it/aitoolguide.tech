---
import { Show, SignInButton, SignUpButton, UserButton } from '@clerk/astro/components';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr" id="html-root">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="AIToolGuide - 2026年最实用的AI赚钱工具导航站，教你用AI工具做副业、接私单、提升收入" />
		<meta name="keywords" content="AI赚钱,AI副业,ChatGPT赚钱,Midjourney赚钱,AI工具,副业赚钱,自由职业,AI写作,AI设计" />
		<meta name="author" content="AIToolGuide Team" />
		<meta name="robots" content="index, follow" />
		<meta name="googlebot" content="index, follow" />
		<meta name="bingbot" content="index, follow" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.aitoolguide.tech/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="2026年最实用的AI赚钱工具导航站，教你用AI工具做副业、接私单、提升收入" />
		<meta property="og:image" content="https://www.aitoolguide.tech/og-image.jpg" />
		<meta property="og:locale" content="zh_CN" />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://www.aitoolguide.tech/" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content="2026年最实用的AI赚钱工具导航站，教你用AI工具做副业、接私单、提升收入" />
		<meta property="twitter:image" content="https://www.aitoolguide.tech/og-image.jpg" />
		
		<!-- Canonical URL -->
		<link rel="canonical" href="https://www.aitoolguide.tech/" />
		
		<!-- Structured Data -->
		<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "AIToolGuide",
			"url": "https://www.aitoolguide.tech",
			"description": "2026年最实用的AI赚钱工具导航站",
			"potentialAction": {
				"@type": "SearchAction",
				"target": "https://www.aitoolguide.tech/search?q={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		}
		</script>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Google Analytics (GA4) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-14213142037" is:inline></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-14213142037');
			// Track CTA button clicks
			document.addEventListener('click', function(e) {
				var btn = e.target.closest('.btn-urgent, .btn-primary, [data-track]');
				if (btn) {
					var label = btn.textContent.trim().substring(0, 50);
					var page = window.location.pathname;
					var lang = localStorage.getItem('aitg_lang') || 'en';
					gtag('event', 'cta_click', {
						'event_category': 'conversion',
						'event_label': label,
						'page_path': page,
						'user_language': lang
					});
				}
			});
			// Track language switches
			var origSetLang = window.AITG_i18n && window.AITG_i18n.setLang;
			if (origSetLang) {
				var _orig = origSetLang;
				window.AITG_i18n.setLang = function(code) {
					gtag('event', 'language_switch', { 'event_category': 'i18n', 'event_label': code });
					return _orig(code);
				};
			}
		</script>
		<!-- Vercel Analytics -->
		<script defer src="/_vercel/insights/script.js" is:inline></script>
		<style is:global>
			:root {
				--primary: #0ea5e9;
				--secondary: #8b5cf6;
				--accent: #f59e0b;
				--dark: #0f172a;
				--gray: #64748b;
				--border: #e2e8f0;
			}
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				line-height: 1.6;
				color: var(--dark);
			}
			a {
				text-decoration: none;
				color: inherit;
			}
			.container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 20px;
			}
			.btn {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 14px 28px;
				border-radius: 10px;
				font-weight: 600;
				font-size: 1rem;
				transition: all 0.3s;
				border: none;
				cursor: pointer;
			}
			.btn-primary {
				background: linear-gradient(135deg, var(--primary), var(--secondary));
				color: white;
				box-shadow: 0 4px 14px rgba(14, 165, 233, 0.4);
			}
			.btn-primary:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 20px rgba(14, 165, 233, 0.5);
			}
			.btn-secondary {
				background: white;
				color: var(--dark);
				border: 2px solid var(--border);
			}
			.btn-secondary:hover {
				border-color: var(--primary);
				color: var(--primary);
			}
			.btn-urgent {
				background: linear-gradient(135deg, #ef4444, #f97316);
				color: white;
				box-shadow: 0 4px 14px rgba(239, 68, 68, 0.4);
				animation: pulse 2s infinite;
			}
			.btn-urgent:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 20px rgba(239, 68, 68, 0.5);
			}
			@keyframes pulse {
				0%, 100% { transform: scale(1); }
				50% { transform: scale(1.02); }
			}
			.btn-large {
				padding: 18px 36px;
				font-size: 1.125rem;
			}
			.money-badge {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				padding: 6px 12px;
				background: linear-gradient(135deg, #fef3c7, #fde68a);
				color: #92400e;
				font-weight: 700;
				font-size: 0.8rem;
				border-radius: 20px;
			}
			.urgency-banner {
				background: linear-gradient(90deg, #fef3c7, #fee2e2);
				padding: 10px;
				text-align: center;
				font-weight: 600;
				color: #92400e;
				font-size: 0.9rem;
			}
			/* RTL Support for Arabic */
			[dir="rtl"] .nav-links {
				flex-direction: row-reverse;
			}
			[dir="rtl"] .hero-actions,
			[dir="rtl"] .cta-actions,
			[dir="rtl"] .bottom-cta-buttons {
				flex-direction: row-reverse;
			}
			[dir="rtl"] .footer-links {
				flex-direction: row-reverse;
			}
			[dir="rtl"] .article-card-footer,
			[dir="rtl"] .tool-detail-header,
			[dir="rtl"] .method-header {
				flex-direction: row-reverse;
			}
		</style>
	</head>
	<body>
		<header class="clerk-header" style="position: fixed; top: 0; right: 0; z-index: 9999; padding: 10px 20px;">
			<Show when="signed-out">
				<SignInButton mode="modal" class="btn btn-primary btn-small" />
				<SignUpButton mode="modal" class="btn btn-secondary btn-small" />
			</Show>
			<Show when="signed-in">
				<UserButton />
			</Show>
		</header>
		<slot />
		<script src="/i18n.js" is:inline></script>
		<script>
			// Immediate language detection to prevent flash of wrong language
			(function() {
				const savedLang = localStorage.getItem('aitg_lang');
				if (savedLang) {
					document.documentElement.lang = savedLang === 'zh-CN' ? 'zh-Hans' : savedLang === 'zh-TW' ? 'zh-Hant' : savedLang;
					if (savedLang === 'ar') {
						document.documentElement.dir = 'rtl';
					}
				}
			})();
		</script>
	</body>
</html>
