---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | AIToolGuide">
  <div class="error-page">
    <div class="error-content">
      <div class="error-illustration">
        <span class="error-icon">🔍</span>
        <div class="error-code">404</div>
      </div>
      
      <h1 data-i18n="error404Title">Page Not Found</h1>
      <p data-i18n="error404Desc">Oops! The page you're looking for seems to have wandered off into the AI universe.</p>
      
      <div class="suggestions">
        <h3 data-i18n="error404Suggestions">You might want to try:</h3>
        <ul>
          <li><a href="/" data-i18n="error404Home">🏠 Back to Home</a></li>
          <li><a href="/ai-tools-100" data-i18n="error404Tools">🛠️ Browse AI Tools</a></li>
          <li><a href="/faq" data-i18n="error404FAQ">❓ Visit FAQ</a></li>
          <li><a href="/blog" data-i18n="error404Blog">📚 Read Success Stories</a></li>
        </ul>
      </div>
      
      <div class="error-actions">
        <a href="/" class="btn btn-primary" data-i18n="error404Cta">Take Me Home →</a>
      </div>
      
      <div class="fun-fact">
        <span class="fact-icon">💡</span>
        <p data-i18n="error404Fact">Fun fact: The first AI program was written in 1951. We've come a long way since then!</p>
      </div>
    </div>
  </div>

  <style>
    .error-page {
      min-height: 100vh;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }

    .error-content {
      text-align: center;
      max-width: 600px;
      color: white;
    }

    .error-illustration {
      margin-bottom: 32px;
    }

    .error-icon {
      font-size: 5rem;
      display: block;
      margin-bottom: 16px;
      animation: float 3s ease-in-out infinite;
    }

    .error-code {
      font-size: 8rem;
      font-weight: 800;
      background: linear-gradient(135deg, #667eea, #764ba2);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1;
      opacity: 0.5;
    }

    .error-content h1 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 16px;
    }

    .error-content > p {
      font-size: 1.1rem;
      opacity: 0.8;
      margin-bottom: 32px;
      line-height: 1.6;
    }

    .suggestions {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 16px;
      padding: 24px;
      margin-bottom: 32px;
      text-align: left;
    }

    .suggestions h3 {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 16px;
      opacity: 0.9;
    }

    .suggestions ul {
      list-style: none;
    }

    .suggestions li {
      margin-bottom: 12px;
    }

    .suggestions a {
      color: white;
      text-decoration: none;
      font-size: 1rem;
      opacity: 0.8;
      transition: all 0.3s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .suggestions a:hover {
      opacity: 1;
      transform: translateX(4px);
    }

    .error-actions {
      margin-bottom: 32px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 16px 32px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.3s;
    }

    .btn-primary {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
    }

    .fun-fact {
      display: flex;
      align-items: center;
      gap: 12px;
      justify-content: center;
      padding: 16px;
      background: rgba(251, 191, 36, 0.1);
      border: 1px solid rgba(251, 191, 36, 0.3);
      border-radius: 12px;
    }

    .fact-icon {
      font-size: 1.5rem;
    }

    .fun-fact p {
      font-size: 0.9rem;
      opacity: 0.9;
      margin: 0;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    @media (max-width: 640px) {
      .error-code {
        font-size: 5rem;
      }

      .error-icon {
        font-size: 3.5rem;
      }

      .error-content h1 {
        font-size: 1.5rem;
      }
    }
  </style>
</Layout>
