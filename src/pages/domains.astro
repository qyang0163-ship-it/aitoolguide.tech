---
import Layout from '../layouts/Layout.astro';
const title = "Premium AI Digital Assets | AIToolGuide";

const domains = [
  { id: "01", name: "ai860.com", tag: "Global Core", desc: "Premium 3-digit infrastructure. The ultimate commercial gateway for AI enterprises." },
  { id: "02", name: "ai960.com", tag: "Regional Power", desc: "Strategic 960m sq km narrative. Top-tier positioning for regional AI giants." },
  { id: "03", name: "ai8880.com", tag: "Prestige", desc: "Triple-8 'Fortune' prefix. High-impact branding for Asian markets." },
  { id: "04", name: "ai9998.com", tag: "Authority", desc: "Peak numerical sequence. Imperial-class identity for AI industry leaders." },
  { id: "05", name: "ai617.com", tag: "Academic", desc: "The Boston Legacy. Direct link to MIT, Harvard & Cambridge AI hubs." },
  { id: "06", name: "ai271.com", tag: "Deep Tech", desc: "Euler's Number (e). The mathematical foundation of neural networks." },
  { id: "07", name: "ai264.com", tag: "Industry Standard", desc: "Video encoding legacy. Ideal for next-gen generative video AI." },
  { id: "08", name: "ai2424.com", tag: "Agentic", desc: "24/7 Autonomy. Designed for AI Agents & Automated SaaS platforms." },
];
---

<Layout title={title}>
  <div class="page">
    <div class="container">
      <!-- Header -->
      <header class="header">
        <div class="lang-switcher">
          <a href="/domains" class="lang-btn active">EN</a>
          <a href="/domains/zh" class="lang-btn">中文</a>
          <a href="/domains/fr" class="lang-btn">FR</a>
          <a href="/domains/de" class="lang-btn">DE</a>
          <a href="/domains/it" class="lang-btn">IT</a>
          <a href="/domains/es" class="lang-btn">ES</a>
        </div>
        <h1 class="title">Premium AI Digital Assets</h1>
        <p class="subtitle">A curated portfolio of high-authority identities for next-generation AI infrastructure and research labs.</p>
      </header>

      <!-- Domain Grid - All 8 Cards -->
      <main class="grid">
        {domains.map((domain) => (
          <a href={`https://${domain.name}`} target="_blank" rel="noopener noreferrer" class="card">
            <div class="card-header">
              <span class="asset-id">ASSET-{domain.id}</span>
              <span class="tag">{domain.tag}</span>
            </div>
            <h2 class="domain-name">{domain.name}</h2>
            <p class="domain-desc">{domain.desc}</p>
            <div class="card-footer">
              <span class="view-link">View Details →</span>
            </div>
          </a>
        ))}
      </main>

      <!-- Footer -->
      <footer class="footer">
        <span>© 2026 ai2424.com — Secure transfer via Escrow, Dan.com, or Aliyun</span>
        <span class="footer-id">AITG-ASSET-2026</span>
      </footer>
    </div>
  </div>

  <style>
    .page {
      background: #000;
      min-height: 100vh;
      color: #fff;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 48px 24px;
    }
    
    /* Header */
    .header {
      margin-bottom: 64px;
    }
    
    .lang-switcher {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      margin-bottom: 48px;
    }
    
    .lang-btn {
      padding: 8px 16px;
      background: transparent;
      color: #666;
      border: 1px solid #333;
      border-radius: 4px;
      font-size: 12px;
      text-decoration: none;
      transition: all 0.2s;
    }
    
    .lang-btn:hover {
      border-color: #555;
      color: #999;
    }
    
    .lang-btn.active {
      background: #fff;
      color: #000;
      border-color: #fff;
    }
    
    .title {
      font-size: 48px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
      color: #fff;
    }
    
    .subtitle {
      color: #888;
      font-size: 18px;
      line-height: 1.6;
      max-width: 640px;
    }
    
    /* Grid - 2 columns, gap-8 */
    .grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
      margin-bottom: 64px;
    }
    
    @media (max-width: 768px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
    
    /* Card - Luxury styling */
    .card {
      display: block;
      background: #0a0a0a;
      border: 1px solid #27272a;
      border-radius: 16px;
      padding: 32px;
      text-decoration: none;
      color: inherit;
      transition: all 0.3s ease;
    }
    
    .card:hover {
      border-color: #52525b;
      box-shadow: 0 0 20px rgba(255, 255, 255, 0.05);
      transform: translateY(-2px);
    }
    
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
    }
    
    .asset-id {
      font-family: 'SF Mono', Monaco, 'Courier New', monospace;
      font-size: 11px;
      color: #52525b;
      letter-spacing: 0.1em;
    }
    
    .tag {
      font-size: 10px;
      color: #a1a1aa;
      background: transparent;
      border: 1px solid #3f3f46;
      padding: 6px 12px;
      border-radius: 9999px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }
    
    .domain-name {
      font-family: 'SF Mono', Monaco, 'Courier New', monospace;
      font-size: 30px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    
    .domain-desc {
      color: #71717a;
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 32px;
      min-height: 48px;
    }
    
    .card-footer {
      display: flex;
      align-items: center;
      gap: 12px;
      padding-top: 24px;
      border-top: 1px solid #27272a;
    }
    
    .view-link {
      font-size: 13px;
      color: #fff;
      border-bottom: 1px solid #fff;
      padding-bottom: 2px;
    }
    
    .separator {
      color: #3f3f46;
    }
    
    .grade {
      font-size: 12px;
      color: #52525b;
      font-style: italic;
    }
    
    /* Footer */
    .footer {
      padding-top: 32px;
      border-top: 1px solid #27272a;
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: #52525b;
    }
    
    .footer-id {
      font-family: 'SF Mono', monospace;
      color: #3f3f46;
    }
  </style>
</Layout>
