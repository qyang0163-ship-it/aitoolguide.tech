---

<Layout title={title}>
  <div class="domains-wrapper">
    <div class="domains-page" id="domains-page">
      <!-- Language Switcher -->
      <div class="lang-bar">
        <div class="lang-switcher">
          <button class="lang-btn active" data-lang="en">EN</button>
          <button class="lang-btn" data-lang="zh">中文</button>
          <button class="lang-btn" data-lang="fr">FR</button>
          <button class="lang-btn" data-lang="de">DE</button>
          <button class="lang-btn" data-lang="it">IT</button>
          <button class="lang-btn" data-lang="es">ES</button>
        </div>
      </div>

      <!-- Header -->
      <header class="domains-header">
        <h1 id="page-title">Premium AI Digital Assets</h1>
        <p id="page-subtitle">A curated portfolio of high-authority identities for next-generation AI infrastructure and research labs.</p>
      </header>

      <!-- Domain Grid -->
      <main class="domains-main">
        <div class="domains-grid" id="domains-grid">
          <!-- Populated by JS -->
        </div>
        
        <!-- Pagination -->
        <div class="pagination" id="pagination">
          <button class="page-btn" id="prev-btn" disabled>←</button>
          <span class="page-info" id="page-info">Page 1 of 2</span>
          <button class="page-btn" id="next-btn">→</button>
        </div>
      </main>

      <!-- Footer -->
      <footer class="domains-footer">
        <span>© 2026 aitoolguide.tech - Secure transfer via Escrow, Dan.com, or Aliyun</span>
        <span class="footer-id">AITG-ASSET-2026</span>
      </footer>
    </div>
  </div>

  <script is:inline define:vars={{ domains, translations }}>
    let currentLang = 'en';
    let currentPage = 1;
    const itemsPerPage = 4;

    function getTag(domain) {
      return domain['tag' + currentLang.toUpperCase()] || domain.tag;
    }

    function getDesc(domain) {
      return domain['desc' + currentLang.toUpperCase()] || domain.desc;
    }

    function renderDomains() {
      const t = translations[currentLang];
      const start = (currentPage - 1) * itemsPerPage;
      const end = start + itemsPerPage;
      const pageDomains = domains.slice(start, end);
      
      const grid = document.getElementById('domains-grid');
      grid.innerHTML = pageDomains.map((domain) => `
        <a href="/domain/${domain.name.replace('.com', '')}" class="domain-card">
          <div class="domain-header">
            <h2 class="domain-name">${domain.name}</h2>
            <span class="domain-tag">${getTag(domain)}</span>
          </div>
          <p class="domain-desc">${getDesc(domain)}</p>
          <div class="domain-footer">
            <span class="domain-view">${t.view} →</span>
            <span class="domain-separator">|</span>
            <span class="domain-grade">${t.grade}</span>
          </div>
        </a>
      `).join('');
      
      // Update pagination
      const totalPages = Math.ceil(domains.length / itemsPerPage);
      document.getElementById('page-info').textContent = `${t.page} ${currentPage} ${t.of} ${totalPages}`;
      document.getElementById('prev-btn').disabled = currentPage === 1;
      document.getElementById('next-btn').disabled = currentPage === totalPages;
    }

    function updateUI() {
      const t = translations[currentLang];
      document.getElementById('page-title').textContent = t.title;
      document.getElementById('page-subtitle').textContent = t.subtitle;
    }

    // Language switch
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentLang = btn.dataset.lang;
        currentPage = 1;
        updateUI();
        renderDomains();
      });
    });

    // Pagination
    document.getElementById('prev-btn').addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        renderDomains();
      }
    });

    document.getElementById('next-btn').addEventListener('click', () => {
      const totalPages = Math.ceil(domains.length / itemsPerPage);
      if (currentPage < totalPages) {
        currentPage++;
        renderDomains();
      }
    });

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      updateUI();
      renderDomains();
    });
  </script>

  <style>
    .domains-wrapper {
      background: #0b0b0b;
      min-height: 100vh;
    }
    
    .domains-page {
      background: #0b0b0b;
      color: #ffffff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    
    /* Language Bar */
    .lang-bar {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 40px;
    }
    
    .lang-switcher {
      display: flex;
      gap: 8px;
    }
    
    .lang-btn {
      padding: 8px 16px;
      background: transparent;
      color: #666;
      border: 1px solid #333;
      border-radius: 4px;
      font-size: 12px;
      cursor: pointer;
      transition: all 0.2s;
    }
    
    .lang-btn:hover {
      border-color: #555;
      color: #999;
    }
    
    .lang-btn.active {
      background: #fff;
      color: #0b0b0b;
      border-color: #fff;
    }
    
    /* Header */
    .domains-header {
      margin-bottom: 60px;
    }
    
    .domains-header h1 {
      font-size: 42px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
      color: #fff;
    }
    
    .domains-header p {
      color: #888;
      font-size: 16px;
      line-height: 1.6;
      max-width: 600px;
    }
    
    /* Grid */
    .domains-main {
      margin-bottom: 40px;
    }
    
    .domains-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      margin-bottom: 40px;
    }
    
    @media (max-width: 768px) {
      .domains-grid {
        grid-template-columns: 1fr;
      }
    }
    
    .domain-card {
      display: block;
      background: #000;
      border: 1px solid #333;
      border-radius: 8px;
      padding: 32px;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s;
    }
    
    .domain-card:hover {
      border-color: #666;
    }
    
    .domain-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 16px;
    }
    
    .domain-name {
      font-family: 'SF Mono', Monaco, 'Courier New', monospace;
      font-size: 24px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.01em;
    }
    
    .domain-tag {
      font-size: 11px;
      color: #888;
      background: #1a1a1a;
      padding: 6px 12px;
      border-radius: 4px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border: 1px solid #333;
    }
    
    .domain-desc {
      color: #666;
      font-size: 14px;
      line-height: 1.6;
      margin-bottom: 24px;
    }
    
    .domain-footer {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    
    .domain-view {
      font-size: 12px;
      color: #fff;
      border-bottom: 1px solid #fff;
      padding-bottom: 2px;
    }
    
    .domain-separator {
      color: #444;
    }
    
    .domain-grade {
      font-size: 12px;
      color: #555;
      font-style: italic;
    }
    
    /* Pagination */
    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 24px;
    }
    
    .page-btn {
      width: 44px;
      height: 44px;
      background: #1a1a1a;
      color: #fff;
      border: 1px solid #333;
      border-radius: 8px;
      font-size: 18px;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .page-btn:hover:not(:disabled) {
      border-color: #555;
      background: #222;
    }
    
    .page-btn:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }
    
    .page-info {
      color: #888;
      font-size: 14px;
      min-width: 100px;
      text-align: center;
    }
    
    /* Footer */
    .domains-footer {
      margin-top: 60px;
      padding-top: 30px;
      border-top: 1px solid #222;
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: #555;
    }
    
    .footer-id {
      color: #444;
    }
  </style>
</Layout>
