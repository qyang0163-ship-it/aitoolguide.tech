---
import Layout from '../layouts/Layout.astro';

const title = "Premium AI Digital Assets | AIToolGuide";

const domains = [
  { name: "ai860.com", tag: "Global Core", tagZh: "全球核心", desc: "Premium 3-digit infrastructure. The ultimate commercial gateway.", descZh: "顶级3位数字基础设施。终极商业门户。" },
  { name: "ai960.com", tag: "Regional Power", tagZh: "区域霸主", desc: "Strategic 960m sq km narrative. Top-tier for regional AI giants.", descZh: "960万平方公里战略叙事。区域AI巨头首选。" },
  { name: "ai8880.com", tag: "Prestige", tagZh: "尊贵象征", desc: "Triple-8 'Fortune' prefix. High-impact branding for Asian markets.", descZh: "三8'发财'前缀。亚洲市场高影响力品牌。" },
  { name: "ai9998.com", tag: "Authority", tagZh: "权威巅峰", desc: "Peak numerical sequence. Imperial-class identity for AI leaders.", descZh: "顶级数字序列。AI领袖的帝王级身份。" },
  { name: "ai617.com", tag: "Academic", tagZh: "学术殿堂", desc: "The Boston Legacy. Direct link to MIT, Harvard & Cambridge AI hubs.", descZh: "波士顿遗产。直通MIT、哈佛、剑桥AI中心。" },
  { name: "ai271.com", tag: "Deep Tech", tagZh: "深度科技", desc: "Euler's Number (e). The mathematical foundation of neural networks.", descZh: "欧拉数(e)。神经网络的数学基础。" },
  { name: "ai264.com", tag: "Industry Standard", tagZh: "行业标准", desc: "Video encoding legacy. Ideal for next-gen generative video AI.", descZh: "视频编码遗产。下一代生成式视频AI的理想选择。" },
  { name: "ai2424.com", tag: "Agentic", tagZh: "智能代理", desc: "24/7 Autonomy. Designed for AI Agents & Automated SaaS.", descZh: "24/7全天候自主。专为AI代理和自动化SaaS设计。" },
];
---

<Layout title={title}>
  <div class="min-h-screen bg-[#0b0b0b] text-white p-8 md:p-12 font-sans" id="domains-page">
    <!-- Language Switcher -->
    <div class="max-w-5xl mx-auto mb-8 flex justify-end">
      <div class="flex gap-2">
        <button class="lang-btn px-3 py-1.5 text-xs border border-zinc-800 rounded bg-zinc-900 text-zinc-400 hover:border-zinc-600 transition-colors active" data-lang="en">EN</button>
        <button class="lang-btn px-3 py-1.5 text-xs border border-zinc-800 rounded bg-transparent text-zinc-500 hover:border-zinc-600 hover:text-zinc-300 transition-colors" data-lang="zh">中文</button>
      </div>
    </div>

    <!-- Header -->
    <header class="max-w-5xl mx-auto mb-16">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tighter mb-4 text-white" id="page-title">Premium AI Digital Assets</h1>
      <p class="text-zinc-500 text-lg max-w-2xl leading-relaxed" id="page-subtitle">
        A curated portfolio of high-authority identities for next-generation AI infrastructure and research labs.
      </p>
    </header>

    <!-- Domain Grid -->
    <main class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="domains-grid">
        {domains.map((domain) => (
          <a href={`/domain/${domain.name.replace('.com', '')}`} class="group block border border-zinc-800 p-6 md:p-8 rounded-lg hover:border-zinc-500 transition-colors bg-black">
            <div class="flex justify-between items-start mb-4">
              <h2 class="text-2xl font-mono font-bold text-white tracking-tight">{domain.name}</h2>
              <span class="domain-tag text-xs bg-zinc-900 text-zinc-400 px-3 py-1.5 rounded tracking-widest uppercase border border-zinc-800 whitespace-nowrap">
                {domain.tag}
              </span>
            </div>
            <p class="domain-desc text-zinc-500 text-sm mb-6 leading-relaxed">{domain.desc}</p>
            <div class="flex gap-4 items-center">
              <span class="text-xs text-white border-b border-white pb-1 group-hover:text-zinc-300 group-hover:border-zinc-300 transition-colors">查看详情</span>
              <span class="text-zinc-700">|</span>
              <span class="text-xs text-zinc-600 italic">Institutional Grade</span>
            </div>
          </a>
        ))}
      </div>
    </main>

    <!-- Footer -->
    <footer class="max-w-5xl mx-auto mt-24 border-t border-zinc-900 pt-8 text-zinc-600 text-xs flex justify-between items-center">
      <span>© 2026 aitoolguide.tech - Secure transfer via Escrow, Dan.com, or Aliyun</span>
      <span class="text-zinc-700">AITG-ASSET-2026</span>
    </footer>
  </div>

  <script is:inline define:vars={{ domains }}>
    const translations = {
      en: {
        title: "Premium AI Digital Assets",
        subtitle: "A curated portfolio of high-authority identities for next-generation AI infrastructure and research labs.",
        viewDetails: "View Details",
        grade: "Institutional Grade"
      },
      zh: {
        title: "顶级 AI 数字资产",
        subtitle: "为下一代 AI 基础设施和研究实验室精心策划的高权威身份组合。",
        viewDetails: "查看详情",
        grade: "机构级"
      }
    };

    let currentLang = 'en';

    function renderDomains() {
      const grid = document.getElementById('domains-grid');
      const t = translations[currentLang];
      
      grid.innerHTML = domains.map((domain) => `
        <a href="/domain/${domain.name.replace('.com', '')}" class="group block border border-zinc-800 p-6 md:p-8 rounded-lg hover:border-zinc-500 transition-colors bg-black">
          <div class="flex justify-between items-start mb-4">
            <h2 class="text-2xl font-mono font-bold text-white tracking-tight">${domain.name}</h2>
            <span class="text-xs bg-zinc-900 text-zinc-400 px-3 py-1.5 rounded tracking-widest uppercase border border-zinc-800 whitespace-nowrap">
              ${currentLang === 'zh' ? domain.tagZh : domain.tag}
            </span>
          </div>
          <p class="text-zinc-500 text-sm mb-6 leading-relaxed">${currentLang === 'zh' ? domain.descZh : domain.desc}</p>
          <div class="flex gap-4 items-center">
            <span class="text-xs text-white border-b border-white pb-1 group-hover:text-zinc-300 group-hover:border-zinc-300 transition-colors">${t.viewDetails}</span>
            <span class="text-zinc-700">|</span>
            <span class="text-xs text-zinc-600 italic">${t.grade}</span>
          </div>
        </a>
      `).join('');
    }

    function updateUI() {
      const t = translations[currentLang];
      document.getElementById('page-title').textContent = t.title;
      document.getElementById('page-subtitle').textContent = t.subtitle;
    }

    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.lang-btn').forEach(b => {
          b.classList.remove('active', 'bg-zinc-900', 'text-zinc-400');
          b.classList.add('bg-transparent', 'text-zinc-500');
        });
        btn.classList.add('active', 'bg-zinc-900', 'text-zinc-400');
        btn.classList.remove('bg-transparent', 'text-zinc-500');
        currentLang = btn.dataset.lang;
        updateUI();
        renderDomains();
      });
    });
  </script>
</Layout>
