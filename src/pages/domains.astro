---

<Layout title={title}>
  <div class="domains-page" id="domains-page">
    <!-- Language Selector -->
    <div class="lang-selector">
      <button class="lang-btn active" data-lang="en">EN</button>
      <button class="lang-btn" data-lang="zh">中文</button>
      <button class="lang-btn" data-lang="fr">FR</button>
      <button class="lang-btn" data-lang="de">DE</button>
      <button class="lang-btn" data-lang="it">IT</button>
      <button class="lang-btn" data-lang="es">ES</button>
    </div>

    <header class="domains-header">
      <h1 id="domains-title">Premium AI Digital Assets</h1>
      <p id="domains-subtitle">A curated portfolio of high-authority identities for next-generation AI infrastructure and research labs.</p>
    </header>

    <main class="domains-container">
      <div class="domains-grid" id="domains-grid">
        <!-- Populated by JavaScript -->
      </div>
    </main>

    <footer class="domains-footer" id="domains-footer">
      © 2026 aitoolguide.tech - Secure transfer via Escrow, Dan.com, or Aliyun.
    </footer>
  </div>

  <script is:inline define:vars={{ domainsData, uiTranslations }}>
    // State
    let currentLang = 'en';
    
    // Get domains for current language
    function getDomains() {
      return domainsData[currentLang] || domainsData['en'];
    }
    
    // Get UI translations
    function getUI() {
      return uiTranslations[currentLang] || uiTranslations['en'];
    }
    
    // Render all domains
    function renderDomains() {
      const domains = getDomains();
      const ui = getUI();
      
      const grid = document.getElementById('domains-grid');
      grid.innerHTML = domains.map(domain => `
        <div class="domain-card">
          <div class="domain-header">
            <h2>${domain.name}</h2>
            <span class="domain-tag">${domain.tag}</span>
          </div>
          <p class="domain-desc">${domain.desc}</p>
          <div class="domain-actions">
            <a href="mailto:invest@aitoolguide.tech?subject=Inquiry: ${domain.name}" class="domain-inquiry">${ui.inquiry}</a>
            <span class="domain-separator">|</span>
            <span class="domain-grade">${ui.grade}</span>
          </div>
        </div>
      `).join('');
    }
    
    // Update UI text
    function updateUI() {
      const ui = getUI();
      document.getElementById('domains-title').textContent = ui.title;
      document.getElementById('domains-subtitle').textContent = ui.subtitle;
      document.getElementById('domains-footer').textContent = ui.footer;
    }
    
    // Language switch
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentLang = btn.dataset.lang;
        updateUI();
        renderDomains();
      });
    });
    
    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      updateUI();
      renderDomains();
    });
  </script>

  <style>
    .domains-page {
      background: #0b0b0b;
      color: white;
      min-height: 100vh;
      padding: 40px 20px;
      font-family: system-ui, -apple-system, sans-serif;
    }
    
    /* Language Selector */
    .lang-selector {
      max-width: 1000px;
      margin: 0 auto 40px;
      display: flex;
      gap: 8px;
      justify-content: center;
      flex-wrap: wrap;
    }
    
    .lang-btn {
      padding: 8px 16px;
      background: #18181b;
      color: #a1a1aa;
      border: 1px solid #27272a;
      border-radius: 6px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }
    
    .lang-btn:hover {
      border-color: #52525b;
      color: white;
    }
    
    .lang-btn.active {
      background: white;
      color: #0b0b0b;
      border-color: white;
    }
    
    .domains-header {
      max-width: 1000px;
      margin: 40px auto 60px;
      text-align: center;
    }
    
    .domains-header h1 {
      font-size: 2.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
      color: white;
    }
    
    .domains-header p {
      color: #9ca3af;
      font-size: 1.1rem;
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.6;
    }
    
    .domains-container {
      max-width: 1000px;
      margin: 0 auto;
    }
    
    .domains-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }
    
    @media (max-width: 768px) {
      .domains-grid {
        grid-template-columns: 1fr;
      }
    }
    
    .domain-card {
      border: 1px solid #27272a;
      padding: 24px;
      border-radius: 8px;
      background: #000;
      transition: border-color 0.3s;
    }
    
    .domain-card:hover {
      border-color: #52525b;
    }
    
    .domain-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 16px;
    }
    
    .domain-header h2 {
      font-family: 'Courier New', monospace;
      font-size: 1.5rem;
      font-weight: 700;
      color: white;
    }
    
    .domain-tag {
      font-size: 0.65rem;
      background: #18181b;
      color: #a1a1aa;
      padding: 4px 8px;
      border-radius: 4px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border: 1px solid #27272a;
    }
    
    .domain-desc {
      color: #6b7280;
      font-size: 0.875rem;
      margin-bottom: 20px;
      line-height: 1.6;
    }
    
    .domain-actions {
      display: flex;
      gap: 12px;
      align-items: center;
    }
    
    .domain-inquiry {
      font-size: 0.75rem;
      color: white;
      border-bottom: 1px solid white;
      padding-bottom: 2px;
      text-decoration: none;
      transition: color 0.3s;
    }
    
    .domain-inquiry:hover {
      color: #a1a1aa;
    }
    
    .domain-separator {
      color: #3f3f46;
    }
    
    .domain-grade {
      font-size: 0.75rem;
      color: #52525b;
      font-style: italic;
    }
    
    .domains-footer {
      max-width: 1000px;
      margin: 60px auto 0;
      border-top: 1px solid #18181b;
      padding-top: 24px;
      color: #52525b;
      font-size: 0.75rem;
      text-align: center;
    }
  </style>
</Layout>
