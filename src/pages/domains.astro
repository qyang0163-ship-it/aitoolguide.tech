---

<Layout title={title}>
  <div class="domains-page" id="domains-page">
    <!-- Minimal Header -->
    <header class="domains-header">
      <div class="header-top">
        <span class="header-id">AITG-ASSET-2026</span>
        <div class="lang-switcher">
          <button class="lang-btn active" data-lang="en">EN</button>
          <button class="lang-btn" data-lang="zh">中文</button>
          <button class="lang-btn" data-lang="fr">FR</button>
          <button class="lang-btn" data-lang="de">DE</button>
          <button class="lang-btn" data-lang="it">IT</button>
          <button class="lang-btn" data-lang="es">ES</button>
        </div>
      </div>
      <h1 id="domains-title">AI Digital Assets</h1>
      <p id="domains-subtitle">Institutional-grade domain portfolio</p>
    </header>

    <!-- Domain Grid -->
    <main class="domains-container">
      <div class="domains-grid" id="domains-grid">
        <!-- Populated by JavaScript -->
      </div>
    </main>

    <!-- Minimal Footer -->
    <footer class="domains-footer">
      <span id="domains-footer">Secure transfer via Escrow · Dan.com · Aliyun</span>
      <span class="footer-id">© 2026</span>
    </footer>
  </div>

  <script is:inline define:vars={{ domainsData, uiTranslations }}>
    let currentLang = 'en';
    
    function getDomains() {
      return domainsData[currentLang] || domainsData['en'];
    }
    
    function getUI() {
      return uiTranslations[currentLang] || uiTranslations['en'];
    }
    
    function renderDomains() {
      const domains = getDomains();
      const ui = getUI();
      
      const grid = document.getElementById('domains-grid');
      grid.innerHTML = domains.map((domain, index) => `
        <a href="${domain.path}" class="domain-card">
          <div class="domain-index">${String(index + 1).padStart(2, '0')}</div>
          <div class="domain-content">
            <div class="domain-header">
              <span class="domain-tag">${domain.tag}</span>
              <h2 class="domain-name">${domain.name}</h2>
            </div>
            <p class="domain-desc">${domain.desc}</p>
            <span class="domain-view">VIEW →</span>
          </div>
        </a>
      `).join('');
    }
    
    function updateUI() {
      const ui = getUI();
      document.getElementById('domains-title').textContent = ui.title;
      document.getElementById('domains-subtitle').textContent = ui.subtitle;
      document.getElementById('domains-footer').textContent = ui.footer;
    }
    
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentLang = btn.dataset.lang;
        updateUI();
        renderDomains();
      });
    });
    
    document.addEventListener('DOMContentLoaded', () => {
      updateUI();
      renderDomains();
    });
  </script>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    .domains-page {
      background: #0a0a0a;
      color: #e5e5e5;
      min-height: 100vh;
      font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Fira Code', monospace;
      padding: 60px 40px;
    }
    
    /* Header */
    .domains-header {
      max-width: 1200px;
      margin: 0 auto 60px;
    }
    
    .header-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 40px;
      padding-bottom: 20px;
      border-bottom: 1px solid #1a1a1a;
    }
    
    .header-id {
      font-size: 11px;
      color: #404040;
      letter-spacing: 0.2em;
    }
    
    .lang-switcher {
      display: flex;
      gap: 4px;
    }
    
    .lang-btn {
      padding: 6px 12px;
      background: transparent;
      color: #606060;
      border: 1px solid #1a1a1a;
      font-size: 11px;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.2s;
      letter-spacing: 0.05em;
    }
    
    .lang-btn:hover {
      border-color: #404040;
      color: #a0a0a0;
    }
    
    .lang-btn.active {
      background: #e5e5e5;
      color: #0a0a0a;
      border-color: #e5e5e5;
    }
    
    .domains-header h1 {
      font-size: 32px;
      font-weight: 400;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
      color: #ffffff;
    }
    
    .domains-header p {
      color: #606060;
      font-size: 13px;
      letter-spacing: 0.05em;
    }
    
    /* Domain Grid */
    .domains-container {
      max-width: 1200px;
      margin: 0 auto;
    }
    
    .domains-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2px;
      background: #1a1a1a;
      border: 2px solid #1a1a1a;
    }
    
    @media (max-width: 900px) {
      .domains-grid {
        grid-template-columns: 1fr;
      }
    }
    
    .domain-card {
      display: flex;
      background: #0a0a0a;
      padding: 50px 40px;
      transition: background 0.2s;
      text-decoration: none;
      color: inherit;
      min-height: 220px;
    }
    
    .domain-card:hover {
      background: #111111;
    }
    
    .domain-index {
      font-size: 12px;
      color: #505050;
      margin-right: 40px;
      padding-top: 4px;
      min-width: 24px;
      font-weight: 500;
    }
    
    .domain-content {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    
    .domain-header {
      margin-bottom: 20px;
    }
    
    .domain-tag {
      display: block;
      font-size: 11px;
      color: #707070;
      letter-spacing: 0.2em;
      margin-bottom: 12px;
      font-weight: 500;
    }
    
    .domain-name {
      font-family: 'SF Mono', 'Monaco', monospace;
      font-size: 28px;
      font-weight: 600;
      color: #ffffff;
      letter-spacing: -0.01em;
      margin: 0;
    }
    
    .domain-desc {
      color: #606060;
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 24px;
      flex: 1;
    }
    
    .domain-view {
      font-size: 11px;
      color: #505050;
      letter-spacing: 0.15em;
      transition: color 0.2s;
      font-weight: 500;
    }
    
    .domain-card:hover .domain-view {
      color: #ffffff;
    }
    
    /* Footer */
    .domains-footer {
      max-width: 1200px;
      margin: 60px auto 0;
      padding-top: 30px;
      border-top: 1px solid #1a1a1a;
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: #404040;
      letter-spacing: 0.05em;
    }
    
    .footer-id {
      color: #303030;
    }
    
    @media (max-width: 768px) {
      .domains-page {
        padding: 40px 20px;
      }
      
      .domain-card {
        padding: 30px 20px;
      }
      
      .domain-index {
        margin-right: 20px;
      }
      
      .domain-name {
        font-size: 20px;
      }
      
      .header-top {
        flex-direction: column;
        gap: 20px;
        align-items: flex-start;
      }
    }
  </style>
</Layout>
