---
import LayoutI18n from '../../layouts/LayoutI18n.astro';
import { getToolData } from '../../../data/tools-i18n.js';
import { formatIncome, getPlatforms } from '../../../config/i18n.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh-cn' } },
    { params: { lang: 'es' } },
    { params: { lang: 'ja' } }
  ];
}

const { lang } = Astro.params;
const tool = getToolData('claude', lang);
const platforms = getPlatforms(lang);

const title = `${tool.name} Money Guide - ${tool.headline}`;
const description = tool.description;
---

<LayoutI18n title={title} description={description} locale={lang} toolId="claude">
  <div class="urgency-banner">
    🔥 Limited: First 100 users get the '{tool.name} Money Toolkit'
  </div>

  <header class="header">
    <div class="container">
      <nav class="nav">
        <a href={`/${lang}/`} class="logo">
          <span class="logo-icon">💰</span>
          <span class="logo-text">AIToolGuide</span>
        </a>
        <div class="nav-links">
          <a href={`/${lang}/#tools`}>Tools</a>
          <a href={`/${lang}/#methods`}>Methods</a>
          <a href={`/${lang}/#stories`}>Stories</a>
        </div>
      </nav>
    </div>
  </header>

  <section class="hero" style={`background: linear-gradient(135deg, ${tool.color}10, ${tool.color}05)`}>
    <div class="container">
      <div class="tool-badge" style={`background: ${tool.color}20; color: ${tool.color}`}>
        <span class="tool-icon-large">{tool.icon}</span>
        <span>{tool.category}</span>
      </div>
      <h1 class="hero-title">{tool.headline}</h1>
      <p class="hero-description">{tool.description}</p>
      
      <div class="hero-stats">
        <div class="stat-card">
          <span class="stat-value">{formatIncome(tool.incomeRange.min, tool.incomeRange.max, lang)}</span>
          <span class="stat-label">Expected Income</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{'⭐'.repeat(tool.difficulty)}</span>
          <span class="stat-label">Difficulty</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{tool.timeToFirstIncome}</span>
          <span class="stat-label">First Income</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">{tool.methods.length} Ways to Make Money</h2>
      <div class="methods-grid">
        {tool.methods.map((method, index) => (
          <div class="method-card">
            <div class="method-header">
              <span class="method-number">Method {index + 1}</span>
              <span class="method-income">{method.income}</span>
            </div>
            <h3>{method.title}</h3>
            <p>{method.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <h2 class="section-title">Where to Get Orders</h2>
      <div class="platforms-grid">
        {platforms.map((platform) => (
          <div class="platform-card">
            <h3>{platform}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>
</LayoutI18n>

<style>
  .urgency-banner { background: linear-gradient(90deg, #fef3c7, #fee2e2); padding: 10px; text-align: center; }
  .header { position: fixed; top: 32px; left: 0; right: 0; background: rgba(255,255,255,0.98); z-index: 1000; }
  .nav { display: flex; align-items: center; justify-content: space-between; height: 70px; max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  .logo { display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 1.5rem; }
  .hero { padding: 140px 0 80px; text-align: center; }
  .tool-badge { display: inline-flex; align-items: center; gap: 10px; padding: 12px 24px; border-radius: 30px; font-weight: 700; margin-bottom: 24px; }
  .hero-title { font-size: 2.8rem; font-weight: 800; margin-bottom: 20px; }
  .hero-stats { display: flex; justify-content: center; gap: 40px; margin-top: 40px; }
  .stat-card { background: white; padding: 24px 40px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
  .section { padding: 80px 0; }
  .section-dark { background: linear-gradient(135deg, #0f172a, #1e293b); color: white; }
  .methods-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(400px, 1fr)); gap: 30px; }
  .platforms-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 24px; }
</style>
