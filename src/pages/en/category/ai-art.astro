---
import LayoutI18n from '../../layouts/LayoutI18n.astro';

const title = 'ai-art Tools - Make Money with AI';
const description = 'Discover the best ai-art tools to start your side hustle and earn money online.';
const lang = 'en';
---

<LayoutI18n title={title} description={description} locale={lang}>
  <div class="container">
    <h1>ai-art Tools</h1>
    <p>Browse all ai-art tools to find your perfect side hustle.</p>
    
    <div class="tools-grid">
      <!-- Tool cards will be dynamically generated -->
    </div>
  </div>
</LayoutI18n>
