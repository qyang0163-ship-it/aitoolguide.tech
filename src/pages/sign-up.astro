---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sign Up - Unlock Exclusive AI Money Guides">
  <div class="auth-page">
    <!-- Header -->
    <header class="header">
      <div class="container">
        <nav class="nav">
          <a href="/" class="logo">
            <span class="logo-icon">💰</span>
            <span class="logo-text">AIToolGuide</span>
          </a>
          <div class="nav-actions">
            <a href="/" class="back-link">← Back to Home</a>
            <!-- Language switcher will be inserted here -->
          </div>
        </nav>
      </div>
    </header>

    <!-- Auth Section -->
    <section class="auth-section">
      <div class="container">
        <div class="auth-box">
          <div class="auth-header">
            <span class="auth-badge">🔥 Exclusive Access</span>
            <h1 data-i18n="signupTitle">Unlock AI Money-Making Guides</h1>
            <p data-i18n="signupSubtitle">Join 12,000+ members already earning with AI tools</p>
          </div>

          <!-- Error Message -->
          <div id="error-message" class="error-message" style="display: none;">
            <span class="error-icon">⚠️</span>
            <span class="error-text"></span>
          </div>

          <!-- Success Message -->
          <div id="success-message" class="success-message" style="display: none;">
            <span class="success-icon">✅</span>
            <span class="success-text"></span>
          </div>

          <!-- Benefits -->
          <div class="benefits">
            <div class="benefit">
              <span class="benefit-icon">📚</span>
              <span data-i18n="benefit1">Step-by-step monetization tutorials</span>
            </div>
            <div class="benefit">
              <span class="benefit-icon">💎</span>
              <span data-i18n="benefit2">Exclusive freelance platforms</span>
            </div>
            <div class="benefit">
              <span class="benefit-icon">🎯</span>
              <span data-i18n="benefit3">Real case studies & income proof</span>
            </div>
            <div class="benefit">
              <span class="benefit-icon">👥</span>
              <span data-i18n="benefit4">Private community access</span>
            </div>
          </div>

          <!-- Sign Up Form -->
          <form id="signup-form" class="auth-form">
            <div class="form-group">
              <label for="email" data-i18n="emailLabel">Email Address</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="your@email.com" 
                required
              />
            </div>
            
            <div class="form-group">
              <label for="password" data-i18n="passwordLabel">Password</label>
              <input 
                type="password" 
                id="password" 
                name="password" 
                placeholder="Create a password (min 8 chars)" 
                minlength="8"
                required
              />
            </div>

            <div class="form-group">
              <label for="referral" data-i18n="referralLabel">How did you hear about us? (Optional)</label>
              <select id="referral" name="referral">
                <option value="" data-i18n="referralSelect">Select an option</option>
                <option value="google" data-i18n="referralGoogle">Google Search</option>
                <option value="social" data-i18n="referralSocial">Social Media</option>
                <option value="friend" data-i18n="referralFriend">Friend Recommendation</option>
                <option value="youtube" data-i18n="referralYoutube">YouTube</option>
                <option value="other" data-i18n="referralOther">Other</option>
              </select>
            </div>

            <div class="form-checkbox">
              <input type="checkbox" id="agree" name="agree" required />
              <label for="agree">
                <span data-i18n="agreeText1">I agree to the</span>
                <a href="#" target="_blank" data-i18n="termsLink">Terms of Service</a>
                <span data-i18n="agreeText2">and</span>
                <a href="#" target="_blank" data-i18n="privacyLink">Privacy Policy</a>
              </label>
            </div>

            <button type="submit" class="btn btn-urgent btn-large">
              <span data-i18n="createAccount">🚀 Create Free Account</span>
            </button>
          </form>

          <!-- Divider -->
          <div class="divider">
            <span data-i18n="orDivider">or</span>
          </div>

          <!-- Google Login -->
          <div class="social-login">
            <!-- 
              GOOGLE OAUTH SETUP REQUIRED:
              1. Go to https://console.cloud.google.com/
              2. Create a new project or select existing
              3. Enable Google Identity Services API
              4. Create OAuth 2.0 credentials (Web application)
              5. Add authorized domain: aitoolguide.tech
              6. Add authorized redirect URIs: https://aitoolguide.tech/sign-up
              7. Copy Client ID and replace YOUR_GOOGLE_CLIENT_ID below
            -->
            <div id="g_id_onload"
                 data-client_id="YOUR_GOOGLE_CLIENT_ID"
                 data-context="signup"
                 data-ux_mode="popup"
                 data-callback="handleGoogleCredentialResponse"
                 data-auto_prompt="false"
                 style="display: none;">
            </div>
            <div class="g_id_signin"
                 data-type="standard"
                 data-shape="rectangular"
                 data-theme="outline"
                 data-text="signup_with"
                 data-size="large"
                 data-logo_alignment="left"
                 style="display: none;">
            </div>
            <!-- Google Sign In - Coming Soon Notice -->
            <div class="google-notice">
              <span class="notice-icon">🔧</span>
              <span class="notice-text">Google Sign In coming soon. Please use email registration for now.</span>
            </div>
          </div>

          <!-- Sign In Link -->
          <div class="auth-footer">
            <p>
              <span data-i18n="haveAccount">Already have an account?</span>
              <a href="/sign-in" data-i18n="signInLink">Sign In</a>
            </p>
          </div>
        </div>

        <!-- Urgency -->
        <div class="urgency-box">
          <span class="urgency-icon">⏰</span>
          <span>
            <strong>153</strong>
            <span data-i18n="spotsRemaining"> spots remaining for this month's free toolkit</span>
          </span>
        </div>
      </div>
    </section>
  </div>

  <!-- Google Identity Services Script - Uncomment when OAuth is configured -->
  <!-- <script src="https://accounts.google.com/gsi/client" async defer></script> -->
</Layout>

<style>
  .auth-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
  }

  /* Header */
  .header {
    padding: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .container {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 1.5rem;
    text-decoration: none;
    color: white;
  }

  .logo-icon { font-size: 1.8rem; }
  .logo-text {
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  #aitg-lang-switcher {
    margin-left: 8px;
  }

  .back-link {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s;
  }

  .back-link:hover {
    color: white;
  }

  /* Auth Section */
  .auth-section {
    padding: 40px 20px;
  }

  .auth-box {
    background: white;
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .auth-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .auth-badge {
    display: inline-block;
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    color: #92400e;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .auth-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 8px;
  }

  .auth-header p {
    color: #64748b;
    font-size: 1rem;
  }

  /* Error & Success Messages */
  .error-message {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
    padding: 12px 16px;
    border-radius: 12px;
    margin-bottom: 20px;
    font-size: 0.9rem;
  }

  .error-icon {
    font-size: 1.2rem;
  }

  .success-message {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #16a34a;
    padding: 12px 16px;
    border-radius: 12px;
    margin-bottom: 20px;
    font-size: 0.9rem;
  }

  .success-icon {
    font-size: 1.2rem;
  }

  /* Benefits */
  .benefits {
    background: #f8fafc;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 32px;
  }

  .benefit {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    font-size: 0.95rem;
    color: #334155;
  }

  .benefit-icon {
    font-size: 1.25rem;
  }

  /* Form */
  .auth-form {
    margin-bottom: 24px;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    color: #334155;
    margin-bottom: 8px;
    font-size: 0.9rem;
  }

  .form-group input,
  .form-group select {
    width: 100%;
    padding: 14px 16px;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    font-size: 1rem;
    transition: all 0.3s;
    box-sizing: border-box;
  }

  .form-group input:focus,
  .form-group select:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  }

  .form-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 24px;
  }

  .form-checkbox input {
    width: 20px;
    height: 20px;
    margin-top: 2px;
    accent-color: #667eea;
  }

  .form-checkbox label {
    font-size: 0.9rem;
    color: #64748b;
    line-height: 1.5;
  }

  .form-checkbox a {
    color: #667eea;
    text-decoration: none;
  }

  .form-checkbox a:hover {
    text-decoration: underline;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 32px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    width: 100%;
  }

  .btn-urgent {
    background: linear-gradient(135deg, #f093fb, #f5576c);
    color: white;
  }

  .btn-urgent:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(245, 87, 108, 0.3);
  }

  .btn-google {
    background: white;
    color: #374151;
    border: 2px solid #e5e7eb;
  }

  .btn-google:hover {
    background: #f9fafb;
    border-color: #d1d5db;
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    margin: 24px 0;
    color: #9ca3af;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e5e7eb;
  }

  .divider span {
    padding: 0 16px;
    font-size: 0.9rem;
  }

  /* Social Login */
  .social-login {
    margin-bottom: 24px;
  }

  .g_id_signin {
    width: 100% !important;
  }

  .google-notice {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #f1f5f9;
    border: 1px dashed #cbd5e1;
    border-radius: 12px;
    padding: 16px;
    color: #64748b;
    font-size: 0.9rem;
    text-align: center;
  }

  .notice-icon {
    font-size: 1.2rem;
  }

  /* Auth Footer */
  .auth-footer {
    text-align: center;
    padding-top: 24px;
    border-top: 1px solid #e5e7eb;
  }

  .auth-footer p {
    color: #64748b;
    font-size: 0.95rem;
  }

  .auth-footer a {
    color: #667eea;
    font-weight: 600;
    text-decoration: none;
  }

  .auth-footer a:hover {
    text-decoration: underline;
  }

  /* Urgency Box */
  .urgency-box {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: rgba(251, 191, 36, 0.2);
    border: 1px solid rgba(251, 191, 36, 0.3);
    border-radius: 12px;
    padding: 16px;
    margin-top: 24px;
    color: #fbbf24;
    font-size: 0.95rem;
  }

  .urgency-icon {
    font-size: 1.25rem;
  }

  .urgency-box strong {
    color: #f59e0b;
  }

  /* Responsive */
  @media (max-width: 480px) {
    .auth-box {
      padding: 24px;
    }

    .auth-header h1 {
      font-size: 1.5rem;
    }

    .benefits {
      padding: 16px;
    }

    .benefit {
      font-size: 0.9rem;
    }
  }
</style>

<script>
  // Show error message
  function showError(message) {
    const errorEl = document.getElementById('error-message');
    const errorText = errorEl.querySelector('.error-text');
    errorText.textContent = message;
    errorEl.style.display = 'flex';
    
    // Hide after 5 seconds
    setTimeout(() => {
      errorEl.style.display = 'none';
    }, 5000);
  }

  // Show success message
  function showSuccess(message) {
    const successEl = document.getElementById('success-message');
    const successText = successEl.querySelector('.success-text');
    successText.textContent = message;
    successEl.style.display = 'flex';
  }

  // Form submission
  document.getElementById('signup-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    
    // Validate password length
    if (password.length < 8) {
      showError('Password must be at least 8 characters long.');
      return;
    }
    
    // Store user data in localStorage (demo mode)
    const users = JSON.parse(localStorage.getItem('aitg_users') || '[]');
    
    // Check if email already exists
    if (users.find(u => u.email === email)) {
      showError('This email is already registered. Please sign in or use a different email.');
      return;
    }
    
    // Create new user
    const newUser = {
      id: Date.now(),
      email: email,
      password: password, // In production, hash this!
      createdAt: new Date().toISOString(),
      referral: document.getElementById('referral').value
    };
    
    users.push(newUser);
    localStorage.setItem('aitg_users', JSON.stringify(users));
    localStorage.setItem('aitg_current_user', JSON.stringify(newUser));
    
    // Show success message
    showSuccess('🎉 Account created successfully! Redirecting...');
    
    // Redirect to home after 1.5 seconds
    setTimeout(() => {
      window.location.href = '/';
    }, 1500);
  });

  // Handle Google Sign In
  function handleGoogleCredentialResponse(response) {
    // Decode the JWT token
    const credential = response.credential;
    const payload = JSON.parse(atob(credential.split('.')[1]));
    
    const email = payload.email;
    const name = payload.name;
    const picture = payload.picture;
    
    // Store user data
    const users = JSON.parse(localStorage.getItem('aitg_users') || '[]');
    
    // Check if user exists
    let user = users.find(u => u.email === email);
    
    if (!user) {
      // Create new user from Google data
      user = {
        id: Date.now(),
        email: email,
        name: name,
        picture: picture,
        provider: 'google',
        createdAt: new Date().toISOString()
      };
      users.push(user);
      localStorage.setItem('aitg_users', JSON.stringify(users));
    }
    
    // Set current user
    localStorage.setItem('aitg_current_user', JSON.stringify(user));
    
    // Show success and redirect
    showSuccess('🎉 Signed in with Google! Redirecting...');
    setTimeout(() => {
      window.location.href = '/';
    }, 1500);
  }

  // Check if Google script loaded
  window.addEventListener('load', function() {
    if (typeof google === 'undefined') {
      // Show fallback button if Google script fails
      document.getElementById('google-signup-fallback').style.display = 'flex';
    }
  });

  // Fallback Google button
  document.getElementById('google-signup-fallback').addEventListener('click', function() {
    showError('Google Sign In is temporarily unavailable. Please use email registration.');
  });
</script>
