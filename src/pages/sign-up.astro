---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sign Up - Unlock Exclusive AI Money Guides">
  <div class="auth-page">
    <!-- Header -->
    <header class="header">
      <div class="container">
        <nav class="nav">
          <a href="/" class="logo">
            <span class="logo-icon">💰</span>
            <span class="logo-text">AIToolGuide</span>
          </a>
          <div class="nav-actions">
            <a href="/" class="back-link">← Back to Home</a>
            <!-- Language switcher will be inserted here -->
          </div>
        </nav>
      </div>
    </header>

    <!-- Auth Section -->
    <section class="auth-section">
      <div class="container">
        <div class="auth-box">
          <div class="auth-header">
            <span class="auth-badge">🔥 Exclusive Access</span>
            <h1>Unlock AI Money-Making Guides</h1>
            <p>Join 12,000+ members already earning with AI tools</p>
          </div>

          <!-- Benefits -->
          <div class="benefits">
            <div class="benefit">
              <span class="benefit-icon">📚</span>
              <span>Step-by-step monetization tutorials</span>
            </div>
            <div class="benefit">
              <span class="benefit-icon">💎</span>
              <span>Exclusive freelance platforms</span>
            </div>
            <div class="benefit">
              <span class="benefit-icon">🎯</span>
              <span>Real case studies & income proof</span>
            </div>
            <div class="benefit">
              <span class="benefit-icon">👥</span>
              <span>Private community access</span>
            </div>
          </div>

          <!-- Sign Up Form -->
          <form id="signup-form" class="auth-form">
            <div class="form-group">
              <label for="email">Email Address</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="your@email.com" 
                required
              />
            </div>
            
            <div class="form-group">
              <label for="password">Password</label>
              <input 
                type="password" 
                id="password" 
                name="password" 
                placeholder="Create a password (min 8 chars)" 
                minlength="8"
                required
              />
            </div>

            <div class="form-group">
              <label for="referral">How did you hear about us? (Optional)</label>
              <select id="referral" name="referral">
                <option value="">Select an option</option>
                <option value="google">Google Search</option>
                <option value="social">Social Media</option>
                <option value="friend">Friend Recommendation</option>
                <option value="youtube">YouTube</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-checkbox">
              <input type="checkbox" id="agree" name="agree" required />
              <label for="agree">
                I agree to the <a href="#" target="_blank">Terms of Service</a> and 
                <a href="#" target="_blank">Privacy Policy</a>
              </label>
            </div>

            <button type="submit" class="btn btn-urgent btn-large">
              <span>🚀 Create Free Account</span>
            </button>
          </form>

          <!-- Divider -->
          <div class="divider">
            <span>or</span>
          </div>

          <!-- Social Login -->
          <div class="social-login">
            <button class="btn btn-google" id="google-signup">
              <svg viewBox="0 0 24 24" width="18" height="18">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              Continue with Google
            </button>
          </div>

          <!-- Sign In Link -->
          <div class="auth-footer">
            <p>Already have an account? <a href="/sign-in">Sign In</a></p>
          </div>
        </div>

        <!-- Urgency -->
        <div class="urgency-box">
          <span class="urgency-icon">⏰</span>
          <span><strong>153</strong> spots remaining for this month's free toolkit</span>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .auth-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
  }

  /* Header */
  .header {
    padding: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .container {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 1.5rem;
    text-decoration: none;
    color: white;
  }

  .logo-icon { font-size: 1.8rem; }
  .logo-text {
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .back-link {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s;
  }

  .back-link:hover {
    color: white;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  #aitg-lang-switcher {
    margin-left: 8px;
  }

  /* Auth Section */
  .auth-section {
    padding: 40px 20px;
  }

  .auth-box {
    background: white;
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .auth-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .auth-badge {
    display: inline-block;
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    color: #92400e;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .auth-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 8px;
  }

  .auth-header p {
    color: #64748b;
    font-size: 1rem;
  }

  /* Benefits */
  .benefits {
    background: #f8fafc;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 32px;
  }

  .benefit {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    font-size: 0.95rem;
    color: #334155;
  }

  .benefit-icon {
    font-size: 1.25rem;
  }

  /* Form */
  .auth-form {
    margin-bottom: 24px;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    color: #334155;
    margin-bottom: 8px;
    font-size: 0.9rem;
  }

  .form-group input,
  .form-group select {
    width: 100%;
    padding: 14px 16px;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    font-size: 1rem;
    transition: all 0.3s;
    box-sizing: border-box;
  }

  .form-group input:focus,
  .form-group select:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  }

  .form-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 24px;
  }

  .form-checkbox input {
    width: 20px;
    height: 20px;
    margin-top: 2px;
    accent-color: #667eea;
  }

  .form-checkbox label {
    font-size: 0.9rem;
    color: #64748b;
    line-height: 1.5;
  }

  .form-checkbox a {
    color: #667eea;
    text-decoration: none;
  }

  .form-checkbox a:hover {
    text-decoration: underline;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 32px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    width: 100%;
  }

  .btn-urgent {
    background: linear-gradient(135deg, #f093fb, #f5576c);
    color: white;
  }

  .btn-urgent:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(245, 87, 108, 0.3);
  }

  .btn-google {
    background: white;
    color: #374151;
    border: 2px solid #e5e7eb;
  }

  .btn-google:hover {
    background: #f9fafb;
    border-color: #d1d5db;
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    margin: 24px 0;
    color: #9ca3af;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e5e7eb;
  }

  .divider span {
    padding: 0 16px;
    font-size: 0.9rem;
  }

  /* Social Login */
  .social-login {
    margin-bottom: 24px;
  }

  /* Auth Footer */
  .auth-footer {
    text-align: center;
    padding-top: 24px;
    border-top: 1px solid #e5e7eb;
  }

  .auth-footer p {
    color: #64748b;
    font-size: 0.95rem;
  }

  .auth-footer a {
    color: #667eea;
    font-weight: 600;
    text-decoration: none;
  }

  .auth-footer a:hover {
    text-decoration: underline;
  }

  /* Urgency Box */
  .urgency-box {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: rgba(251, 191, 36, 0.2);
    border: 1px solid rgba(251, 191, 36, 0.3);
    border-radius: 12px;
    padding: 16px;
    margin-top: 24px;
    color: #fbbf24;
    font-size: 0.95rem;
  }

  .urgency-icon {
    font-size: 1.25rem;
  }

  .urgency-box strong {
    color: #f59e0b;
  }

  /* Responsive */
  @media (max-width: 480px) {
    .auth-box {
      padding: 24px;
    }

    .auth-header h1 {
      font-size: 1.5rem;
    }

    .benefits {
      padding: 16px;
    }

    .benefit {
      font-size: 0.9rem;
    }
  }
</style>

<script>
  // Form submission
  document.getElementById('signup-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    
    // Store user data in localStorage (demo mode)
    const users = JSON.parse(localStorage.getItem('aitg_users') || '[]');
    
    // Check if email already exists
    if (users.find(u => u.email === email)) {
      alert('This email is already registered. Please sign in.');
      return;
    }
    
    // Create new user
    const newUser = {
      id: Date.now(),
      email: email,
      password: password, // In production, hash this!
      createdAt: new Date().toISOString(),
      referral: document.getElementById('referral').value
    };
    
    users.push(newUser);
    localStorage.setItem('aitg_users', JSON.stringify(users));
    localStorage.setItem('aitg_current_user', JSON.stringify(newUser));
    
    // Show success message
    alert('🎉 Account created successfully! Welcome to AIToolGuide.');
    
    // Redirect to home or VIP page
    window.location.href = '/';
  });

  // Google Sign Up (placeholder)
  document.getElementById('google-signup').addEventListener('click', function() {
    alert('Google Sign Up coming soon! Please use email registration.');
  });
</script>
