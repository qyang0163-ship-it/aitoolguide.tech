---
// English homepage - Statically generated at build time
// URL: /en/

import LayoutI18n from '../../layouts/LayoutI18n.astro';
import { getAllTools } from '../../data/tools-i18n.js';
import { formatIncome, getPlatforms } from '../../config/i18n.js';

const locale = 'en';
const tools = getAllTools(locale);
const platforms = getPlatforms(locale);

const title = 'AIToolGuide - Make Money with AI Tools | 2026';
const description = 'Discover 50+ AI tools to start your side hustle. Step-by-step tutorials, real income data, and proven strategies to earn $500-$3,000/month.';
---

<LayoutI18n title={title} description={description} locale={locale}>
  <!-- Urgency Banner -->
  <div class="urgency-banner">
    🔥 Limited: First 100 users get the 'AI Money Toolkit' + Exclusive Freelance Channels
  </div>

  <!-- Header -->
  <header class="header">
    <div class="container">
      <nav class="nav">
        <a href={`/${locale}/`} class="logo">
          <span class="logo-icon">💰</span>
          <span class="logo-text">AIToolGuide</span>
          <span class="logo-tag">#1 Side Hustle</span>
        </a>
        <div class="nav-links">
          <a href={`/${locale}/#tools`}>Money Tools</a>
          <a href={`/${locale}/#methods`}>Methods</a>
          <a href={`/${locale}/#stories`}>Success Stories</a>
          <a href={`/${locale}/#start`}>Get Started</a>
        </div>
        <a href={`/${locale}/#tools`} class="btn btn-primary btn-small">Start Earning Free →</a>
      </nav>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge-group">
          <span class="hero-badge">💸 #1 Side Hustle Choice</span>
          <span class="money-badge">Helped 10,000+ people</span>
        </div>
        <h1 class="hero-title">
          Make Money Easily<br>
          <span class="gradient-text">with AI Tools</span><br>
          Even Beginners Can Earn $1,000+/Month
        </h1>
        <p class="hero-description">
          No coding skills needed. No design experience required. Just learn AI tools and seize the biggest opportunity in 2026.
          <br><br>
          <strong>10 AI Money Tools + Step-by-Step Tutorials + Exclusive Channels</strong> — We'll guide you!
        </p>
        
        <div class="hero-actions">
          <a href={`/${locale}/#tools`} class="btn btn-urgent btn-large">🔥 Try Free Now</a>
          <a href={`/${locale}/#methods`} class="btn btn-primary btn-large">See Methods →</a>
          <a href={`/${locale}/#stories`} class="btn btn-secondary btn-large">Success Stories</a>
        </div>

        <div class="urgency-box">
          <span class="urgency-icon">⏰</span>
          <span>This week <strong>1,247</strong> people started earning</span>
          <span class="urgency-countdown">Limited spots</span>
        </div>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-number">50+</span>
            <span class="stat-label">AI Money Tools</span>
          </div>
          <div class="stat">
            <span class="stat-number">10K+</span>
            <span class="stat-label">Success Cases</span>
          </div>
          <div class="stat">
            <span class="stat-number">$700</span>
            <span class="stat-label">Avg Monthly Income</span>
          </div>
          <div class="stat">
            <span class="stat-number">98%</span>
            <span class="stat-label">Beginner Success</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Steps Section -->
  <section class="steps-section" id="start">
    <div class="container">
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <div class="step-icon">🎯</div>
          <h3>Pick a Tool</h3>
          <p>Choose the right AI tool for your skills</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <div class="step-icon">📖</div>
          <h3>Learn Methods</h3>
          <p>Follow our proven tutorials</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <div class="step-icon">💰</div>
          <h3>Start Earning</h3>
          <p>Land your first paying client</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools Section -->
  <section class="tools-section" id="tools">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">💰 Tested & Proven</span>
        <h2 class="section-title">Top AI Money-Making Tools</h2>
        <p class="section-description">Each tool comes with detailed tutorials and real income data</p>
      </div>

      <div class="tools-grid">
        {tools.map((tool, index) => (
          <div class="tool-card">
            <div class="tool-header" style={`border-left-color: ${tool.color}`}>
              <div class="tool-icon" style={`background: ${tool.color}15`}>
                <span style={`color: ${tool.color}`}>{tool.icon}</span>
              </div>
              <div class="tool-info">
                <h3 class="tool-name">{tool.name}</h3>
                <span class="tool-category">{tool.category}</span>
              </div>
              <span class="income-badge">
                {formatIncome(tool.incomeRange.min, tool.incomeRange.max, locale)}
              </span>
            </div>
            
            <p class="tool-description">{tool.description}</p>
            
            <div class="tool-meta">
              <div class="meta-item">
                <span class="meta-label">Difficulty:</span>
                <span class="meta-value">{'⭐'.repeat(tool.difficulty)}</span>
              </div>
              <div class="meta-item">
                <span class="meta-label">First Income:</span>
                <span class="meta-value">{tool.timeToFirstIncome}</span>
              </div>
            </div>
            
            <div class="tool-actions">
              <a href={`https://chat.openai.com/?ref=aitoolguide`} target="_blank" class="btn btn-urgent">
                🚀 Try Free Now
              </a>
              <a href={`/${locale}/tool/${tool.id}/`} class="btn btn-secondary">
                📖 View Tutorial
              </a>
            </div>
            
            {index < 3 && <span class="hot-badge">🔥 Trending</span>}
          </div>
        ))}
      </div>

      <div class="view-all">
        <a href={`/${locale}/#all-tools`} class="btn btn-primary btn-large">
          View All 50+ Tools →
        </a>
      </div>
    </div>
  </section>

  <!-- Platforms Section -->
  <section class="platforms-section" id="platforms">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">📱 Where to Get Orders</span>
        <h2 class="section-title">Recommended Platforms</h2>
        <p class="section-description">Best platforms to find clients in your market</p>
      </div>
      
      <div class="platforms-grid">
        {platforms.map((platform) => (
          <div class="platform-card">
            <h3>{platform}</h3>
            <a href="#" class="btn btn-primary">Start Now →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section" id="final-cta">
    <div class="container">
      <div class="cta-content">
        <span class="cta-badge">🎁 Limited Offer</span>
        <h2 class="cta-title">Still watching? Others are already earning!</h2>
        <p class="cta-description">
          Register now and get:<br>
          ✅ 'AI Money Toolkit' (Worth $40)<br>
          ✅ Exclusive freelance channels<br>
          ✅ 1-on-1 mentoring (first 100)
        </p>
        
        <div class="cta-actions">
          <a href={`/${locale}/#tools`} class="btn btn-urgent btn-large">🔥 Start Earning Now (Free)</a>
          <a href={`/${locale}/#tools`} class="btn btn-primary btn-large">💎 Get Toolkit</a>
        </div>
        
        <div class="cta-urgency">
          ⏰ <strong>12,847</strong> people joined | <strong>153</strong> spots remaining
        </div>
      </div>
    </div>
  </section>

  <!-- Language Switcher -->
  <div class="lang-switcher-fixed">
    <select onchange="window.location.href='/' + this.value + '/'">
      <option value="en" selected>🇺🇸 English</option>
      <option value="zh-cn">🇨🇳 简体中文</option>
      <option value="zh-tw">🇹🇼 繁體中文</option>
      <option value="es">🇪🇸 Español</option>
      <option value="ja">🇯🇵 日本語</option>
      <option value="pt">🇧🇷 Português</option>
      <option value="vi">🇻🇳 Tiếng Việt</option>
      <option value="th">🇹🇭 ภาษาไทย</option>
      <option value="id">🇮🇩 Bahasa Indonesia</option>
      <option value="hi">🇮🇳 हिन्दी</option>
      <option value="de">🇩🇪 Deutsch</option>
      <option value="fr">🇫🇷 Français</option>
      <option value="ko">🇰🇷 한국어</option>
      <option value="ar">🇸🇦 العربية</option>
      <option value="ru">🇷🇺 Русский</option>
      <option value="tr">🇹🇷 Türkçe</option>
    </select>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <div class="logo">
            <span class="logo-icon">💰</span>
            <span class="logo-text">AIToolGuide</span>
          </div>
          <p class="footer-description">AI tool monetization. Helping everyone create income with AI.</p>
        </div>
        
        <div class="footer-links">
          <div class="footer-column">
            <h4>Money Tools</h4>
            <a href={`/${locale}/tool/chatgpt/`}>ChatGPT</a>
            <a href={`/${locale}/tool/midjourney/`}>Midjourney</a>
            <a href={`/${locale}/tool/notion/`}>Notion AI</a>
          </div>
          
          <div class="footer-column">
            <h4>Guides</h4>
            <a href={`/${locale}/blog/`}>Beginner Guide</a>
            <a href="#">Advanced Tips</a>
            <a href="#">Platforms</a>
          </div>
        </div>
      </div>
      
      <div class="footer-bottom">
        <p>© 2026 AIToolGuide.tech. All rights reserved.</p>
      </div>
    </div>
  </footer>
</LayoutI18n>

<style>
  .urgency-banner {
    background: linear-gradient(90deg, #fef3c7, #fee2e2);
    padding: 10px;
    text-align: center;
    font-weight: 600;
    color: #92400e;
    font-size: 0.9rem;
  }
  
  .header {
    position: fixed;
    top: 32px;
    left: 0;
    right: 0;
    background: rgba(255,255,255,0.98);
    backdrop-filter: blur(10px);
    z-index: 1000;
    border-bottom: 1px solid var(--border);
  }
  
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 1.5rem;
  }
  
  .logo-icon { font-size: 1.8rem; }
  
  .logo-text {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .logo-tag {
    font-size: 0.7rem;
    background: linear-gradient(135deg, #f59e0b, #ef4444);
    color: white;
    padding: 4px 10px;
    border-radius: 12px;
    font-weight: 700;
  }
  
  .nav-links {
    display: flex;
    gap: 30px;
  }
  
  .nav-links a {
    font-weight: 600;
    color: var(--gray);
  }
  
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    border-radius: 10px;
    font-weight: 600;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
  }
  
  .btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
  }
  
  .btn-urgent {
    background: linear-gradient(135deg, #ef4444, #f97316);
    color: white;
    animation: pulse 2s infinite;
  }
  
  .btn-secondary {
    background: white;
    color: var(--dark);
    border: 2px solid var(--border);
  }
  
  .btn-large {
    padding: 16px 32px;
    font-size: 1.1rem;
  }
  
  .btn-small {
    padding: 10px 20px;
    font-size: 0.9rem;
  }
  
  .hero {
    padding: 140px 0 80px;
    text-align: center;
  }
  
  .hero-badge-group {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    color: #92400e;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 20px;
  }
  
  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 24px;
  }
  
  .gradient-text {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .hero-description {
    font-size: 1.25rem;
    color: var(--gray);
    max-width: 600px;
    margin: 0 auto 32px;
  }
  
  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  
  .urgency-box {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    background: white;
    border: 2px solid var(--border);
    border-radius: 50px;
    font-size: 0.95rem;
    color: var(--gray);
    margin-bottom: 40px;
  }
  
  .urgency-countdown {
    color: #ef4444;
    font-weight: 700;
  }
  
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 60px;
    flex-wrap: wrap;
  }
  
  .stat {
    text-align: center;
  }
  
  .stat-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .stat-label {
    color: var(--gray);
    font-size: 0.9rem;
  }
  
  .steps-section {
    padding: 60px 0;
    background: #f8fafc;
  }
  
  .steps {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }
  
  .step {
    text-align: center;
    max-width: 200px;
  }
  
  .step-number {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    margin: 0 auto 12px;
  }
  
  .step-icon {
    font-size: 2.5rem;
    margin-bottom: 12px;
  }
  
  .tools-section {
    padding: 80px 0;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 50px;
  }
  
  .section-badge {
    display: inline-block;
    padding: 8px 20px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
    font-weight: 700;
    border-radius: 20px;
    margin-bottom: 16px;
  }
  
  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 16px;
  }
  
  .section-description {
    color: var(--gray);
    font-size: 1.1rem;
  }
  
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
    margin-bottom: 40px;
  }
  
  .tool-card {
    background: white;
    border: 2px solid var(--border);
    border-radius: 20px;
    padding: 24px;
    position: relative;
  }
  
  .tool-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--border);
    border-left: 4px solid;
    padding-left: 16px;
  }
  
  .tool-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }
  
  .tool-info {
    flex: 1;
  }
  
  .tool-name {
    font-size: 1.3rem;
    font-weight: 700;
  }
  
  .tool-category {
    font-size: 0.85rem;
    color: var(--gray);
  }
  
  .income-badge {
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    color: #92400e;
    padding: 6px 14px;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.85rem;
  }
  
  .tool-description {
    color: #475569;
    margin-bottom: 16px;
  }
  
  .tool-meta {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
    font-size: 0.9rem;
  }
  
  .meta-item {
    display: flex;
    gap: 6px;
  }
  
  .meta-label {
    color: var(--gray);
  }
  
  .tool-actions {
    display: flex;
    gap: 12px;
  }
  
  .hot-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: linear-gradient(135deg, #ef4444, #f97316);
    color: white;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 700;
  }
  
  .view-all {
    text-align: center;
  }
  
  .platforms-section {
    padding: 80px 0;
    background: #f8fafc;
  }
  
  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 24px;
  }
  
  .platform-card {
    background: white;
    padding: 30px;
    border-radius: 16px;
    text-align: center;
    border: 2px solid var(--border);
  }
  
  .platform-card h3 {
    margin-bottom: 16px;
  }
  
  .cta-section {
    padding: 80px 0;
    background: linear-gradient(135deg, #0f172a, #1e293b);
    text-align: center;
    color: white;
  }
  
  .cta-badge {
    display: inline-block;
    padding: 8px 20px;
    background: linear-gradient(135deg, #f59e0b, #ef4444);
    color: white;
    font-weight: 700;
    border-radius: 20px;
    margin-bottom: 20px;
  }
  
  .cta-title {
    font-size: 2.5rem;
    margin-bottom: 20px;
  }
  
  .cta-description {
    font-size: 1.2rem;
    color: rgba(255,255,255,0.8);
    margin-bottom: 40px;
  }
  
  .cta-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  
  .cta-urgency {
    color: rgba(255,255,255,0.6);
  }
  
  .lang-switcher-fixed {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 1000;
  }
  
  .lang-switcher-fixed select {
    padding: 10px 15px;
    border-radius: 10px;
    border: 2px solid var(--border);
    background: white;
    font-size: 0.9rem;
    cursor: pointer;
  }
  
  .footer {
    background: #020617;
    color: white;
    padding: 60px 0 30px;
  }
  
  .footer-content {
    display: flex;
    justify-content: space-between;
    margin-bottom: 40px;
    gap: 60px;
  }
  
  .footer-description {
    color: #94a3b8;
    margin-top: 16px;
  }
  
  .footer-links {
    display: flex;
    gap: 60px;
  }
  
  .footer-column h4 {
    margin-bottom: 20px;
  }
  
  .footer-column a {
    display: block;
    color: #94a3b8;
    margin-bottom: 12px;
  }
  
  .footer-bottom {
    text-align: center;
    padding-top: 30px;
    border-top: 1px solid rgba(255,255,255,0.1);
    color: #64748b;
  }
  
  @media (max-width: 768px) {
    .hero-title { font-size: 2rem; }
    .hero-actions { flex-direction: column; }
    .tools-grid { grid-template-columns: 1fr; }
    .footer-content { flex-direction: column; }
  }
</style>
