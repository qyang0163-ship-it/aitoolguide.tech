---
import Layout from '../../layouts/Layout.astro';

const articles = [
  { slug: 'ai-money-tools', title: 'AI赚钱工具大全', titleEn: 'AI Money Tools Guide', desc: '10个真正能赚钱的AI工具（附实操教程）', tag: '🔥 热门', tagColor: '#ef4444' },
  { slug: 'chatgpt-make-money', title: 'ChatGPT怎么赚钱', titleEn: 'How to Make Money with ChatGPT', desc: '2026年实测5种方法，新手也能月入8000+', tag: '📖 教程', tagColor: '#0ea5e9' },
  { slug: 'ai-side-hustle', title: 'AI副业项目推荐', titleEn: 'AI Side Hustle Projects', desc: '最靠谱的8个AI副业，在家就能做', tag: '💡 推荐', tagColor: '#8b5cf6' },
  { slug: 'best-ai-tools-2026', title: 'AI工具推荐2026', titleEn: 'Best AI Tools 2026', desc: '精选20款最值得用的AI工具', tag: '⭐ 精选', tagColor: '#f59e0b' },
  { slug: 'midjourney-make-money', title: 'Midjourney赚钱攻略', titleEn: 'Midjourney Money Guide', desc: '零基础也能靠AI绘画月入15000+', tag: '🎨 绘画', tagColor: '#6366f1' },
  { slug: 'notion-ai-guide', title: 'Notion AI用法大全', titleEn: 'Notion AI Complete Guide', desc: '从入门到精通，附赚钱变现方法', tag: '📝 效率', tagColor: '#000000' },
  { slug: 'ai-writing-money', title: 'AI写作赚钱', titleEn: 'AI Writing for Money', desc: '用AI写作月入5000-20000的完整方案', tag: '✍️ 写作', tagColor: '#10b981' },
  { slug: 'ai-art-freelance', title: 'AI绘画接单指南', titleEn: 'AI Art Freelance Guide', desc: '靠AI绘画月入5000-20000的方法', tag: '🖼️ 设计', tagColor: '#ec4899' },
  { slug: 'free-ai-tools', title: '免费AI工具大全', titleEn: 'Free AI Tools Collection', desc: '30个好用且免费的AI工具推荐', tag: '🆓 免费', tagColor: '#14b8a6' },
  { slug: 'top-ai-tools-collection', title: '最强AI工具合集', titleEn: 'Top AI Tools Collection', desc: '2026年各领域TOP AI工具一网打尽', tag: '🏆 合集', tagColor: '#f97316' }
];
---

<Layout title="AI赚钱攻略 - 所有文章 | ai2424.com">
  <div class="urgency-banner" data-i18n="urgencyBanner">
    🔥 限时福利：前100名注册用户可获得《AI赚钱工具包》+ 独家接单渠道
  </div>

  <header class="header">
    <div class="container">
      <nav class="nav">
        <a href="/" class="logo">
          <span class="logo-icon">💰</span>
          <span class="logo-text">AIToolGuide</span>
          <span class="logo-tag">赚钱版</span>
        </a>
        <div class="nav-links">
          <a href="/" data-i18n="navTools">赚钱工具</a>
          <a href="/#methods" data-i18n="navMethods">变现方法</a>
          <a href="/#stories" data-i18n="navStories">成功案例</a>
        </div>
        <a href="/#tools" class="btn btn-primary btn-small" data-i18n="navCta">免费开始赚钱 →</a>
      </nav>
    </div>
  </header>

  <main class="blog-list">
    <div class="container">
      <div class="blog-header">
        <span class="section-badge">📚 赚钱攻略</span>
        <h1>AI赚钱攻略全集</h1>
        <p>10篇深度文章，手把手教你用AI赚钱。从工具选择到实操变现，一站解决。</p>
      </div>

      <div class="articles-grid">
        {articles.map((article, index) => (
          <a href={`/blog/${article.slug}/`} class="article-card">
            <div class="article-card-top">
              <span class="article-tag" style={`background: ${article.tagColor}15; color: ${article.tagColor}`}>{article.tag}</span>
              <span class="article-number">#{index + 1}</span>
            </div>
            <h2 class="article-card-title">{article.title}</h2>
            <p class="article-card-title-en">{article.titleEn}</p>
            <p class="article-card-desc">{article.desc}</p>
            <div class="article-card-footer">
              <span class="read-more">阅读全文 →</span>
              <span class="read-time">约8分钟</span>
            </div>
          </a>
        ))}
      </div>

      <div class="blog-cta">
        <div class="blog-cta-content">
          <h2 data-i18n="ctaTitle">还在观望？别人已经开始赚钱了！</h2>
          <a href="/#tools" class="btn btn-urgent btn-large" data-i18n="ctaCta1">🔥 立即开始赚钱（免费）</a>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-bottom">
        <p data-i18n="footerCopyright">© 2026 ai2424.com 赚钱版. All rights reserved.</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .urgency-banner { background: linear-gradient(90deg, #fef3c7, #fee2e2); padding: 10px; text-align: center; font-weight: 600; color: #92400e; font-size: 0.9rem; }
  .header { position: fixed; top: 32px; left: 0; right: 0; background: rgba(255,255,255,0.98); backdrop-filter: blur(10px); z-index: 1000; border-bottom: 1px solid var(--border); }
  .nav { display: flex; align-items: center; justify-content: space-between; height: 70px; }
  .logo { display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 1.5rem; }
  .logo-icon { font-size: 1.8rem; }
  .logo-text { background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .logo-tag { font-size: 0.7rem; background: linear-gradient(135deg, #f59e0b, #ef4444); color: white; padding: 4px 10px; border-radius: 12px; font-weight: 700; }
  .nav-links { display: flex; gap: 30px; }
  .nav-links a { font-weight: 600; color: var(--gray); }
  .btn-small { padding: 10px 20px; font-size: 0.9rem; }

  .blog-list { padding: 140px 0 60px; }
  .blog-header { text-align: center; margin-bottom: 50px; }
  .section-badge { display: inline-block; padding: 8px 20px; background: linear-gradient(135deg, var(--primary), var(--secondary)); color: white; font-weight: 700; border-radius: 20px; margin-bottom: 16px; }
  .blog-header h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 16px; }
  .blog-header p { color: var(--gray); font-size: 1.1rem; }

  .articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px; margin-bottom: 60px; }
  .article-card { background: white; border: 2px solid var(--border); border-radius: 20px; padding: 30px; transition: all 0.3s; display: flex; flex-direction: column; }
  .article-card:hover { border-color: var(--primary); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.1); }
  .article-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .article-tag { padding: 6px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; }
  .article-number { color: var(--gray); font-size: 0.85rem; font-weight: 600; }
  .article-card-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 6px; color: var(--dark); }
  .article-card-title-en { font-size: 0.85rem; color: var(--gray); margin-bottom: 12px; }
  .article-card-desc { color: #475569; line-height: 1.6; flex: 1; margin-bottom: 20px; }
  .article-card-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 16px; border-top: 1px solid var(--border); }
  .read-more { color: var(--primary); font-weight: 600; font-size: 0.95rem; }
  .read-time { color: var(--gray); font-size: 0.85rem; }

  .blog-cta { background: linear-gradient(135deg, #0f172a, #1e293b); border-radius: 20px; padding: 50px; text-align: center; }
  .blog-cta h2 { color: white; font-size: 1.8rem; margin-bottom: 24px; }

  .footer { background: #020617; color: white; padding: 30px 0; }
  .footer-bottom { text-align: center; color: #64748b; font-size: 0.875rem; }

  @media (max-width: 768px) {
    .blog-list { padding: 120px 20px 40px; }
    .blog-header h1 { font-size: 1.8rem; }
    .articles-grid { grid-template-columns: 1fr; }
    .nav-links { display: none; }
    .blog-cta { padding: 30px 20px; }
    .blog-cta h2 { font-size: 1.4rem; }
  }
</style>
