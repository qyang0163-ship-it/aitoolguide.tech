// 生成静态路径
export function getStaticPaths() {
  const slugs = [
    'ai-money-tools', 'chatgpt-make-money', 'ai-side-hustle',
    'best-ai-tools-2026', 'midjourney-make-money', 'notion-ai-guide',
    'ai-writing-money', 'ai-art-freelance', 'free-ai-tools',
    'top-ai-tools-collection'
  ];
  return slugs.map(slug => ({
    params: { slug },
    props: { slug }
  }));
}

