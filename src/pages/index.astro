---
import Layout from '../layouts/Layout.astro';
import { toolData, categoryMap, formatIncome, getDifficultyStars } from '../data/tools.js';

// Get current locale from URL or localStorage (handled by client-side JS)
const title = "AIToolGuide - Make Money with AI Tools | 2026";
---

<Layout title={title}>
  <!-- Urgency Banner -->
  <div class="urgency-banner" data-i18n="urgencyBanner">
    🔥 Limited Offer: First 100 users get the 'AI Money Toolkit' + Exclusive Freelance Channels
  </div>

  <!-- Header -->
  <header class="header">
    <div class="container">
      <nav class="nav">
        <a href="/" class="logo">
          <span class="logo-icon">💰</span>
          <span class="logo-text">AIToolGuide</span>
          <span class="logo-tag" data-i18n="heroBadge">💸 #1 Side Hustle</span>
        </a>
        <div class="nav-links">
          <a href="#tools" data-i18n="navTools">Money Tools</a>
          <a href="#methods" data-i18n="navMethods">Methods</a>
          <a href="#stories" data-i18n="navStories">Success Stories</a>
          <a href="/ai-tools-100" data-i18n="navTop100">Top 100 AI</a>
          <a href="/domains" class="nav-invest" data-i18n="navDomains">Premium Domains <span class="invest-badge">🔥</span></a>
          <a href="#start" data-i18n="navStart">Get Started</a>
        </div>
        <div class="nav-actions">
          <a href="#tools" class="btn btn-primary btn-small" data-i18n="navCta">Start Earning Free →</a>
          <div id="user-menu" class="user-menu" style="display: none;">
            <span class="user-email"></span>
            <a href="/member" class="btn btn-secondary btn-small">Member Center</a>
            <button onclick="signOut()" class="btn btn-ghost btn-small">Sign Out</button>
          </div>
          <a href="/sign-in" id="login-btn" class="btn btn-secondary btn-small">Sign In</a>
          <!-- Language switcher will be inserted here by i18n.js -->
        </div>
      </nav>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge-group">
          <span class="hero-badge" data-i18n="heroBadge">💸 #1 Side Hustle Choice</span>
          <span class="money-badge" data-i18n="heroSocial">Helped 10,000+ people</span>
        </div>
        <h1 class="hero-title">
          <span data-i18n="heroTitle1">Make Money Easily</span>
          <span class="gradient-text" data-i18n="heroTitle2">with AI Tools</span>
          <br>
          <span data-i18n="heroTitle3">Even Beginners Can Earn $1,000+/Month</span>
        </h1>
        <p class="hero-description">
          <span data-i18n="heroDesc">No coding skills needed. No design experience required.</span>
          <br>
          <strong data-i18n="heroDescStrong">10 AI Money Tools + Step-by-Step Tutorials</strong>
          <span data-i18n="heroDescEnd"> — We'll guide you!</span>
        </p>
        
        <div class="hero-actions">
          <a href="#tools" class="btn btn-urgent btn-large" data-i18n="heroCta1">🔥 Try Free Now</a>
          <a href="#methods" class="btn btn-primary btn-large" data-i18n="heroCta2">See Methods →</a>
          <a href="#stories" class="btn btn-secondary btn-large" data-i18n="heroCta3">Success Stories</a>
        </div>

        <div class="urgency-box">
          <span class="urgency-icon">⏰</span>
          <span>
            <span data-i18n="urgencyText">This week</span>
            <strong data-i18n="urgencyCount">1,247</strong>
            <span data-i18n="urgencyPeople">people started earning</span>
          </span>
          <span class="urgency-countdown" data-i18n="urgencyLimit">Limited spots</span>
        </div>

        <div class="live-users">
          <span class="live-dot"></span>
          <span id="live-user-count">127</span>
          <span data-i18n="liveUsersText">people learning now</span>
        </div>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-number" data-i18n="stat1Num">50+</span>
            <span class="stat-label" data-i18n="stat1Label">AI Money Tools</span>
          </div>
          <div class="stat">
            <span class="stat-number" data-i18n="stat2Num">10K+</span>
            <span class="stat-label" data-i18n="stat2Label">Success Cases</span>
          </div>
          <div class="stat">
            <span class="stat-number" data-i18n="stat3Num">$700</span>
            <span class="stat-label" data-i18n="stat3Label">Avg Monthly Income</span>
          </div>
          <div class="stat">
            <span class="stat-number" data-i18n="stat4Num">98%</span>
            <span class="stat-label" data-i18n="stat4Label">Beginner Success</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Steps Section -->
  <section class="steps-section" id="start">
    <div class="container">
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <div class="step-icon">🎯</div>
          <h3 data-i18n="step1Title">Pick a Tool</h3>
          <p data-i18n="step1Desc">Choose the right AI tool</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <div class="step-icon">📖</div>
          <h3 data-i18n="step2Title">Learn Methods</h3>
          <p data-i18n="step2Desc">Follow tutorials & cases</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <div class="step-icon">💰</div>
          <h3 data-i18n="step3Title">Start Earning</h3>
          <p data-i18n="step3Desc">Take action, land first gig</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools Section -->
  <section class="tools-section" id="tools">
    <div class="container">
      <div class="section-header">
        <span class="section-badge" data-i18n="sectionToolsBadge">💰 Tested & Proven</span>
        <h2 class="section-title" data-i18n="sectionToolsTitle">Top 10 AI Money-Making Tools</h2>
        <p class="section-description" data-i18n="sectionToolsDesc">Each tool comes with detailed tutorials</p>
      </div>

      <div class="tools-grid">
        {toolData.map((tool, index) => (
          <div class="tool-card" data-tool-id={tool.id}>
            <div class="tool-header" style={`border-left-color: ${tool.color}`}>
              <div class="tool-icon" style={`background: ${tool.color}15`}>
                <span style={`color: ${tool.color}`}>{tool.icon}</span>
              </div>
              <div class="tool-info">
                <h3 class="tool-name">{tool.name}</h3>
                <span class="tool-category" data-i18n={categoryMap[tool.category]?.key || "catWriting"}>
                  {categoryMap[tool.category]?.default || "AI Writing"}
                </span>
              </div>
              <span class="income-badge" data-income-min={tool.incomeRange.min} data-income-max={tool.incomeRange.max}>
                <!-- Income will be formatted by JS based on locale -->
              </span>
            </div>
            
            <p class="tool-description" data-i18n={`toolDesc_${tool.id}`}>
              Tool description loading...
            </p>
            
            <div class="tool-meta">
              <div class="meta-item">
                <span class="meta-label" data-i18n="earningMethod">Method:</span>
                <span class="meta-value" data-i18n={`method_${tool.id}`}>Loading...</span>
              </div>
              <div class="meta-item">
                <span class="meta-label" data-i18n="difficulty">Difficulty:</span>
                <span class="meta-value difficulty-stars" data-difficulty={tool.difficulty}></span>
              </div>
            </div>
            
            <div class="tool-actions">
              {tool.tier === 'commission' ? (
                <>
                  <a href={tool.url} target="_blank" class="btn btn-urgent" data-track={`tool_${tool.id}_try`}>
                    <span data-i18n={tool.ctaKey}>{tool.ctaDefault}</span>
                  </a>
                  <span class="partner-badge" data-i18n="partnerPerks">🎁 Official Partner Perks</span>
                </>
              ) : (
                <>
                  <a href="/sign-in" class="btn btn-urgent tool-login-link" data-track={`tool_${tool.id}_unlock`}>
                    <span data-i18n={tool.ctaKey}>{tool.ctaDefault}</span>
                  </a>
                  <a href={tool.externalUrl} target="_blank" class="btn btn-urgent tool-visit-link" style="display: none;" data-track={`tool_${tool.id}_try`}>
                    <span data-i18n="tryFree">🚀 Try Free Now</span>
                  </a>
                </>
              )}
              <a href={`/tool/${tool.id}/`} class="btn btn-secondary" data-i18n="viewTutorial" data-track={`tool_${tool.id}_tutorial`}>
                📖 View Tutorial
              </a>
            </div>
            
            {index < 3 && <span class="hot-badge" data-i18n="hotBadge">🔥 Trending</span>}
          </div>
        ))}
      </div>

      <div class="view-all">
        <a href="/ai-tools-100" class="btn btn-primary btn-large" data-i18n="viewAllTools">
          View All 50+ Money Tools →
        </a>
      </div>
    </div>
  </section>

  <!-- Smart Recommendations Section -->
  <section class="recommendations-section" id="recommendations">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">🤖 AI Recommended</span>
        <h2 class="section-title">Personalized For You</h2>
        <p class="section-description">Based on your interests and earning goals</p>
      </div>
      
      <div class="recommendation-tabs">
        <button class="tab-btn active" data-tab="trending" data-i18n="tabTrending">🔥 Trending</button>
        <button class="tab-btn" data-tab="beginner" data-i18n="tabBeginner">🌱 Beginner Friendly</button>
        <button class="tab-btn" data-tab="passive" data-i18n="tabPassive">💤 Passive Income</button>
        <button class="tab-btn" data-tab="similar" data-i18n="tabSimilar">💡 You May Like</button>
      </div>
      
      <div class="recommendations-grid" id="recommendations-grid">
        <!-- Populated by JavaScript -->
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="categories-section" id="methods">
    <div class="container">
      <div class="section-header">
        <span class="section-badge" data-i18n="sectionMethodsBadge">🎯 Choose Your Path</span>
        <h2 class="section-title" data-i18n="sectionMethodsTitle">6 AI Monetization Tracks</h2>
        <p class="section-description" data-i18n="sectionMethodsDesc">Find the best way to earn</p>
      </div>

      <div class="categories-grid">
        <div class="category-card" onclick="checkAuthAndNavigate('/category/ai-writing')">
          <span class="category-icon">✍️</span>
          <h3 data-i18n="catWriting">AI Writing</h3>
          <p data-i18n="catWritingDesc">Copywriting, content creation</p>
          <span class="category-count">15 tools</span>
          <span class="category-cta" data-i18n="startEarning">Start Earning →</span>
          <span class="lock-icon">🔒</span>
        </div>
        <div class="category-card" onclick="checkAuthAndNavigate('/category/ai-art')">
          <span class="category-icon">🎨</span>
          <h3 data-i18n="catArt">AI Art</h3>
          <p data-i18n="catArtDesc">Avatar customization, design orders</p>
          <span class="category-count">12 tools</span>
          <span class="category-cta" data-i18n="startEarning">Start Earning →</span>
          <span class="lock-icon">🔒</span>
        </div>
        <div class="category-card" onclick="checkAuthAndNavigate('/category/ai-video')">
          <span class="category-icon">🎬</span>
          <h3 data-i18n="catVideo">Video Editing</h3>
          <p data-i18n="catVideoDesc">Short videos, ad production</p>
          <span class="category-count">8 tools</span>
          <span class="category-cta" data-i18n="startEarning">Start Earning →</span>
          <span class="lock-icon">🔒</span>
        </div>
        <div class="category-card" onclick="checkAuthAndNavigate('/category/ai-code')">
          <span class="category-icon">💻</span>
          <h3 data-i18n="catCode">Code & Tech</h3>
          <p data-i18n="catCodeDesc">Development, script customization</p>
          <span class="category-count">10 tools</span>
          <span class="category-cta" data-i18n="startEarning">Start Earning →</span>
          <span class="lock-icon">🔒</span>
        </div>
        <div class="category-card" onclick="checkAuthAndNavigate('/category/ai-knowledge')">
          <span class="category-icon">📚</span>
          <h3 data-i18n="catKnowledge">Knowledge</h3>
          <p data-i18n="catKnowledgeDesc">Courses, templates, resources</p>
          <span class="category-count">20 tools</span>
          <span class="category-cta" data-i18n="startEarning">Start Earning →</span>
          <span class="lock-icon">🔒</span>
        </div>
        <div class="category-card" onclick="checkAuthAndNavigate('/category/ai-productivity')">
          <span class="category-icon">⚡</span>
          <h3 data-i18n="catProductivity">Productivity</h3>
          <p data-i18n="catProductivityDesc">Automation, efficiency boost</p>
          <span class="category-count">6 tools</span>
          <span class="category-cta" data-i18n="startEarning">Start Earning →</span>
          <span class="lock-icon">🔒</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Learning Progress Section -->
  <section class="progress-section" id="progress">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">📊 Your Journey</span>
        <h2 class="section-title">Learning Progress</h2>
        <p class="section-description">Track your AI money-making journey</p>
      </div>
      
      <div class="progress-dashboard">
        <div class="progress-stats">
          <div class="progress-stat">
            <span class="progress-number" id="tools-viewed">0</span>
            <span class="progress-label">Tools Explored</span>
          </div>
          <div class="progress-stat">
            <span class="progress-number" id="categories-tried">0</span>
            <span class="progress-label">Categories Tried</span>
          </div>
          <div class="progress-stat">
            <span class="progress-number" id="user-level">Beginner</span>
            <span class="progress-label">Current Level</span>
          </div>
          <div class="progress-stat">
            <span class="progress-number" id="next-milestone">5</span>
            <span class="progress-label">Next Milestone</span>
          </div>
        </div>
        
        <div class="progress-bar-container">
          <div class="progress-bar">
            <div class="progress-fill" id="progress-fill" style="width: 0%"></div>
          </div>
          <p class="progress-text" id="progress-text">Start exploring tools to earn your first badge!</p>
        </div>
        
        <div class="achievements">
          <div class="achievement" id="badge-explorer" data-locked="true">
            <span class="achievement-icon">🔍</span>
            <span class="achievement-name">Explorer</span>
            <span class="achievement-desc">View 3 tools</span>
          </div>
          <div class="achievement" id="badge-curious" data-locked="true">
            <span class="achievement-icon">🧐</span>
            <span class="achievement-name">Curious</span>
            <span class="achievement-desc">Try 2 categories</span>
          </div>
          <div class="achievement" id="badge-learner" data-locked="true">
            <span class="achievement-icon">📚</span>
            <span class="achievement-name">Learner</span>
            <span class="achievement-desc">View 5 tools</span>
          </div>
          <div class="achievement" id="badge-master" data-locked="true">
            <span class="achievement-icon">🏆</span>
            <span class="achievement-name">Master</span>
            <span class="achievement-desc">Try 4 categories</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stories Section -->
  <section class="stories-section" id="stories">
    <div class="container">
      <div class="section-header">
        <span class="section-badge" data-i18n="sectionStoriesBadge">⭐ Real Stories</span>
        <h2 class="section-title" data-i18n="sectionStoriesTitle">They're All Making Money with AI</h2>
        <p class="section-description" data-i18n="sectionStoriesDesc">Real success stories</p>
      </div>

      <div class="stories-grid">
        <article class="story-card">
          <div class="story-header">
            <span class="story-tag beginner-friendly" data-i18n="tagBeginner">Beginner Friendly</span>
            <span class="story-income" data-i18n="storyIncome1">$850/month</span>
          </div>
          <h3 data-i18n="storyTitle1">Student Earns $850/Month with ChatGPT Writing</h3>
          <p data-i18n="storyDesc1">College student uses ChatGPT to help clients write copy and optimize resumes, earning steady $850/month in spare time</p>
          <div class="story-footer">
            <span class="story-date">2026-03-20</span>
            <a href="/tool/chatgpt/" class="story-link" data-i18n="viewDetails">View Details →</a>
          </div>
        </article>

        <article class="story-card">
          <div class="story-header">
            <span class="story-tag designer" data-i18n="tagDesigner">Designer Must-Read</span>
            <span class="story-income" data-i18n="storyIncome2">$2,800/month</span>
          </div>
          <h3 data-i18n="storyTitle2">Designer Doubles Income with Midjourney</h3>
          <p data-i18n="storyDesc2">Graphic designer uses Midjourney to assist design work, increasing order efficiency by 3x and monthly income exceeding $2,800</p>
          <div class="story-footer">
            <span class="story-date">2026-03-18</span>
            <a href="/tool/midjourney/" class="story-link" data-i18n="viewDetails">View Details →</a>
          </div>
        </article>

        <article class="story-card">
          <div class="story-header">
            <span class="story-tag passive" data-i18n="tagPassive">Passive Income</span>
            <span class="story-income" data-i18n="storyIncome3">$700/month</span>
          </div>
          <h3 data-i18n="storyTitle3">Mom Earns $700/Month Passive Income with Notion Templates</h3>
          <p data-i18n="storyDesc3">Full-time mom creates Notion templates and sells on social platforms, achieving passive income while balancing family and work</p>
          <div class="story-footer">
            <span class="story-date">2026-03-15</span>
            <a href="/tool/notion/" class="story-link" data-i18n="viewDetails">View Details →</a>
          </div>
        </article>

        <article class="story-card">
          <div class="story-header">
            <span class="story-tag beginner" data-i18n="tagBeginner">Beginner Friendly</span>
            <span class="story-income" data-i18n="storyIncome4">$1,200/month</span>
          </div>
          <h3 data-i18n="storyTitle4">College Student Pays Tuition with ChatGPT Writing</h3>
          <p data-i18n="storyDesc4">University student uses ChatGPT to help classmates with essays and assignments, earning $1,200/month part-time</p>
          <div class="story-footer">
            <span class="story-date">2026-03-10</span>
            <a href="/category/ai-writing" class="story-link" data-i18n="viewDetails">View Details →</a>
          </div>
        </article>

        <article class="story-card">
          <div class="story-header">
            <span class="story-tag designer" data-i18n="tagDesigner">Designer Must-Read</span>
            <span class="story-income" data-i18n="storyIncome5">$3,500/month</span>
          </div>
          <h3 data-i18n="storyTitle5">Video Editor Scales to $3.5K with Runway AI</h3>
          <p data-i18n="storyDesc5">Freelance video editor uses Runway AI to speed up editing workflow, taking on 3x more clients and scaling income</p>
          <div class="story-footer">
            <span class="story-date">2026-03-05</span>
            <a href="/tool/runway/" class="story-link" data-i18n="viewDetails">View Details →</a>
          </div>
        </article>

        <article class="story-card">
          <div class="story-header">
            <span class="story-tag passive" data-i18n="tagPassive">Passive Income</span>
            <span class="story-income" data-i18n="storyIncome6">$450/month</span>
          </div>
          <h3 data-i18n="storyTitle6">Developer Sells AI Prompts for Recurring Revenue</h3>
          <p data-i18n="storyDesc6">Software engineer packages and sells high-quality AI prompts, building a passive income stream with minimal maintenance</p>
          <div class="story-footer">
            <span class="story-date">2026-02-28</span>
            <a href="/category/ai-knowledge" class="story-link" data-i18n="viewDetails">View Details →</a>
          </div>
        </article>
      </div>

      <div class="stories-footer">
        <a href="#all-stories" class="btn btn-primary" data-i18n="viewAllStories">View All Success Stories →</a>
        <a href="#submit" class="btn btn-secondary" data-i18n="shareYourStory">Share Your Story</a>
      </div>
    </div>
  </section>

  <!-- Latest News Section -->
  <section class="news-section" id="news">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">📰 Latest Updates</span>
        <h2 class="section-title">AI Money Making News</h2>
        <p class="section-description">Stay updated with the latest trends and opportunities</p>
      </div>

      <div class="news-grid">
        <article class="news-card">
          <span class="news-date">Mar 26, 2026</span>
          <span class="news-tag">Trend</span>
          <h3>ChatGPT-5 Released: New Opportunities</h3>
          <p>OpenAI's latest model brings enhanced capabilities for content creators, opening new revenue streams in AI-assisted writing and consulting.</p>
          <a href="#" class="news-link">Read More →</a>
        </article>

        <article class="news-card">
          <span class="news-date">Mar 25, 2026</span>
          <span class="news-tag">Success Story</span>
          <h3>From $0 to $50K: Sarah's AI Journey</h3>
          <p>How a former teacher built a six-figure AI content agency in just 8 months using the methods from our VIP program.</p>
          <a href="/tool/chatgpt/" class="news-link">Read More →</a>
        </article>

        <article class="news-card">
          <span class="news-date">Mar 24, 2026</span>
          <span class="news-tag">Tool Update</span>
          <h3>Midjourney V7: Better Images, More Profit</h3>
          <p>The latest version delivers photorealistic results, making AI art services even more valuable for designers and agencies.</p>
          <a href="/tool/midjourney/" class="news-link">Read More →</a>
        </article>

        <article class="news-card">
          <span class="news-date">Mar 23, 2026</span>
          <span class="news-tag">Opportunity</span>
          <h3>AI Video Editing Boom: $10K/Month Potential</h3>
          <p>New tools like Runway Gen-3 are creating massive demand for AI video editors. Learn how to capitalize on this trend.</p>
          <a href="/category/ai-video" class="news-link">Read More →</a>
        </article>
      </div>

      <div class="news-footer">
        <a href="/blog" class="btn btn-secondary">View All News →</a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section" id="final-cta">
    <div class="container">
      <div class="cta-content">
        <span class="cta-badge" data-i18n="ctaBadge">🎁 Limited Offer</span>
        <h2 class="cta-title" data-i18n="ctaTitle">Still watching? Others are already earning!</h2>
        <p class="cta-description">
          <span data-i18n="ctaDesc1">Register now and get:</span><br>
          <span data-i18n="ctaDesc2">✅ 'AI Money Toolkit' (Worth $40)</span><br>
          <span data-i18n="ctaDesc3">✅ Exclusive freelance channels</span><br>
          <span data-i18n="ctaDesc4">✅ 1-on-1 mentoring (first 100)</span>
        </p>
        
        <div class="cta-actions">
