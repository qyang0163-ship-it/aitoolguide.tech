  <!-- Client-side i18n initialization for dynamic content -->
  <script is:inline>
    // Format income based on current locale
    function formatIncomeForLocale(min, max, locale) {
      const currencyMap = {
        'zh-CN': { symbol: '￥', rate: 1, suffix: '/月' },
        'zh-TW': { symbol: 'NT$', rate: 4.5, suffix: '/月' },
        'en': { symbol: '$', rate: 0.14, suffix: '/month' },
        'es': { symbol: '€', rate: 0.13, suffix: '/mes' },
        'ja': { symbol: '¥', rate: 21, suffix: '/月' },
        'pt': { symbol: 'R$', rate: 0.72, suffix: '/mês' },
        'vi': { symbol: '₫', rate: 3500, suffix: '/tháng' },
        'th': { symbol: '฿', rate: 5, suffix: '/เดือน' },
        'id': { symbol: 'Rp', rate: 2200, suffix: '/bulan' },
        'hi': { symbol: '₹', rate: 12, suffix: '/महीना' },
        'de': { symbol: '€', rate: 0.13, suffix: '/Monat' },
        'fr': { symbol: '€', rate: 0.13, suffix: '/mois' },
        'ko': { symbol: '₩', rate: 190, suffix: '/월' },
        'ar': { symbol: 'د.إ', rate: 0.52, suffix: '/شهر' },
        'ru': { symbol: '₽', rate: 13, suffix: '/мес' },
        'tr': { symbol: '₺', rate: 4.8, suffix: '/ay' }
      };
      const config = currencyMap[locale] || currencyMap['en'];
      const minLocal = Math.round(min * config.rate);
      const maxLocal = Math.round(max * config.rate);
      return config.symbol + minLocal.toLocaleString() + '-' + maxLocal.toLocaleString() + config.suffix;
    }

    // Get difficulty stars
    function getDifficultyStars(level) {
      return '⭐'.repeat(level);
    }

    // Update dynamic content when i18n is ready
    function updateDynamicContent() {
      const lang = localStorage.getItem('aitg_lang') || 'en';
      
      // Update income badges
      document.querySelectorAll('[data-income-min]').forEach(el => {
        const min = parseInt(el.dataset.incomeMin);
        const max = parseInt(el.dataset.incomeMax);
        el.textContent = formatIncomeForLocale(min, max, lang);
      });
      
      // Update difficulty stars
      document.querySelectorAll('[data-difficulty]').forEach(el => {
        const level = parseInt(el.dataset.difficulty);
        el.textContent = getDifficultyStars(level);
      });
    }

    // Run on page load and when language changes
    document.addEventListener('DOMContentLoaded', function() {
      updateDynamicContent();
      checkUserStatus();
    });
    window.addEventListener('storage', function(e) {
      if (e.key === 'aitg_lang') updateDynamicContent();
      if (e.key === 'aitg_current_user') checkUserStatus();
    });

    // Check user login status
    function checkUserStatus() {
      const currentUser = localStorage.getItem('aitg_current_user');
      const userMenu = document.getElementById('user-menu');
      const loginBtn = document.getElementById('login-btn');
      
      if (currentUser) {
        const user = JSON.parse(currentUser);
        if (userMenu) {
          userMenu.style.display = 'flex';
          userMenu.querySelector('.user-email').textContent = user.email;
        }
        if (loginBtn) loginBtn.style.display = 'none';
      } else {
        if (userMenu) userMenu.style.display = 'none';
        if (loginBtn) loginBtn.style.display = 'inline-flex';
      }
    }

    // Sign out function
    function signOut() {
      localStorage.removeItem('aitg_current_user');
      alert('👋 You have been signed out.');
      window.location.reload();
    }

    // Update tool buttons based on login status
    function updateToolButtons() {
      const currentUser = localStorage.getItem('aitg_current_user');
      const isLoggedIn = !!currentUser;
      
      document.querySelectorAll('.tool-actions').forEach(actions => {
        const loginLink = actions.querySelector('.tool-login-link');
        const visitLink = actions.querySelector('.tool-visit-link');
        
        if (loginLink && visitLink) {
          if (isLoggedIn) {
            loginLink.style.display = 'none';
            visitLink.style.display = 'inline-flex';
          } else {
            loginLink.style.display = 'inline-flex';
            visitLink.style.display = 'none';
          }
        }
      });
    }

    // Run on page load
    document.addEventListener('DOMContentLoaded', function() {
      updateDynamicContent();
      checkUserStatus();
      updateToolButtons();
    });
    window.addEventListener('storage', function(e) {
      if (e.key === 'aitg_lang') updateDynamicContent();
      if (e.key === 'aitg_current_user') {
        checkUserStatus();
        updateToolButtons();
      }
    });
  </script>
