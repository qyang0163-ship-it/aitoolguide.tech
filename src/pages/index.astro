  .login-modal.active { display: flex; }
  .login-modal-content {
    background: white;
    padding: 40px;
    border-radius: 20px;
    max-width: 500px;
    text-align: center;
    animation: modalSlideIn 0.3s;
  }
  @keyframes modalSlideIn {
    from { transform: translateY(-50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .login-modal h3 { font-size: 1.5rem; margin-bottom: 16px; }
  .login-modal p { color: #64748b; margin-bottom: 24px; }
  .login-modal .btn { margin: 8px; }
  .login-modal .close { 
    position: absolute; 
    top: 20px; 
    right: 20px; 
    font-size: 1.5rem; 
    cursor: pointer;
    color: #64748b;
  }
  
  /* Recommendations Section */
  .recommendations-section { padding: 80px 0; background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%); }
  .recommendation-tabs { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 40px; }
  .tab-btn { padding: 12px 24px; border: 2px solid var(--border); border-radius: 50px; background: white; font-weight: 600; cursor: pointer; transition: all 0.3s; }
  .tab-btn:hover { border-color: var(--primary); color: var(--primary); }
  .tab-btn.active { background: linear-gradient(135deg, var(--primary), var(--secondary)); color: white; border-color: transparent; }
  .recommendations-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }
  .recommendation-card { background: white; border: 2px solid var(--border); border-radius: 16px; padding: 24px; transition: all 0.3s; position: relative; }
  .recommendation-card:hover { border-color: var(--primary); box-shadow: var(--shadow-lg); transform: translateY(-4px); }
  .rec-badge { position: absolute; top: 12px; right: 12px; padding: 4px 12px; background: linear-gradient(135deg, #f59e0b, #ef4444); color: white; font-size: 0.75rem; font-weight: 700; border-radius: 12px; }
  .rec-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .rec-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
  .rec-info h3 { font-size: 1.1rem; margin-bottom: 4px; }
  .rec-category { font-size: 0.85rem; color: var(--text-muted); }
  .rec-income { color: #ef4444; font-weight: 700; font-size: 1.1rem; margin-bottom: 12px; }
  .rec-reason { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 16px; padding: 12px; background: var(--bg-secondary); border-radius: 8px; }
  .rec-actions { display: flex; gap: 12px; }
  .rec-actions .btn { flex: 1; }
  
  /* Progress Section */
  .progress-section { padding: 80px 0; background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%); }
  .progress-dashboard { background: white; border-radius: 24px; padding: 40px; box-shadow: var(--shadow-lg); }
  .progress-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 40px; }
  .progress-stat { text-align: center; padding: 24px; background: var(--bg-secondary); border-radius: 16px; }
  .progress-number { display: block; font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 8px; }
  .progress-label { font-size: 0.9rem; color: var(--text-muted); }
  .progress-bar-container { margin-bottom: 40px; }
  .progress-bar { height: 12px; background: var(--bg-secondary); border-radius: 6px; overflow: hidden; margin-bottom: 16px; }
  .progress-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--secondary)); border-radius: 6px; transition: width 0.5s ease; }
  .progress-text { text-align: center; color: var(--text-secondary); font-size: 1.1rem; }
  .achievements { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .achievement { text-align: center; padding: 24px; background: var(--bg-secondary); border-radius: 16px; transition: all 0.3s; }
  .achievement[data-locked="true"] { opacity: 0.5; filter: grayscale(1); }
  .achievement.unlocked { background: linear-gradient(135deg, #dcfce7, #bbf7d0); border: 2px solid #22c55e; }
  .achievement-icon { display: block; font-size: 2.5rem; margin-bottom: 12px; }
  .achievement-name { display: block; font-weight: 700; color: var(--text-primary); margin-bottom: 4px; }
  .achievement-desc { font-size: 0.85rem; color: var(--text-muted); }
  
  /* Floating CTA */
  .floating-cta { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%) translateY(100px); z-index: 999; opacity: 0; transition: all 0.3s ease; }
  .floating-cta.visible { transform: translateX(-50%) translateY(0); opacity: 1; }
  .floating-cta-btn { display: flex; flex-direction: column; align-items: center; padding: 12px 24px; background: linear-gradient(135deg, #ef4444, #f97316); color: white; border-radius: 50px; text-decoration: none; box-shadow: 0 4px 20px rgba(239, 68, 68, 0.4); animation: pulse 2s infinite; }
  .floating-cta-btn span { font-weight: 700; font-size: 1rem; }
  .floating-cta-btn small { font-size: 0.75rem; opacity: 0.9; }
  @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
  
  /* Nav Invest Badge */
  .nav-invest { position: relative; }
  .invest-badge { font-size: 0.7rem; margin-left: 4px; }
  
  @media (max-width: 1024px) {
    .nav-links a { font-size: 0.85rem; }
  }
  
  @media (max-width: 768px) {
    .progress-stats { grid-template-columns: repeat(2, 1fr); }
    .achievements { grid-template-columns: repeat(2, 1fr); }
    .floating-cta-btn { padding: 10px 20px; }
    .floating-cta-btn span { font-size: 0.9rem; }
  }
</style>

<script is:inline>
  // Check authentication status
  function isAuthenticated() {
    const user = localStorage.getItem('aitg_current_user');
    return user && JSON.parse(user)?.isSignedIn === true;
  }

  // Check auth and navigate
  function checkAuthAndNavigate(path) {
    if (isAuthenticated()) {
      window.location.href = path;
    } else {
      showLoginModal();
      sessionStorage.setItem('postLoginRedirect', path);
    }
  }

  function showLoginModal() {
    document.getElementById('login-modal').classList.add('active');
  }

  function closeLoginModal() {
    document.getElementById('login-modal').classList.remove('active');
  }

  function redirectToSignUp() {
    closeLoginModal();
    window.location.href = '/sign-up';
  }

  // Close modal on outside click
  document.addEventListener('click', function(e) {
    const modal = document.getElementById('login-modal');
    if (e.target === modal) {
      closeLoginModal();
    }
  });

  // Auto-redirect after login
  if (isAuthenticated() && sessionStorage.getItem('postLoginRedirect')) {
    const redirect = sessionStorage.getItem('postLoginRedirect');
    sessionStorage.removeItem('postLoginRedirect');
    window.location.href = redirect;
  }
  
  // Smart Recommendations System
  const toolDatabase = [
    { id: "chatgpt", name: "ChatGPT", icon: "💬", color: "#10a37f", category: "writing", difficulty: 2, incomeMin: 3000, incomeMax: 8000, tier: "private" },
    { id: "midjourney", name: "Midjourney", icon: "🎨", color: "#6366f1", category: "art", difficulty: 3, incomeMin: 5000, incomeMax: 15000, tier: "private" },
    { id: "claude", name: "Claude", icon: "🧠", color: "#d97706", category: "writing", difficulty: 2, incomeMin: 4000, incomeMax: 10000, tier: "private" },
    { id: "notion", name: "Notion AI", icon: "📝", color: "#000000", category: "productivity", difficulty: 1, incomeMin: 2000, incomeMax: 6000, tier: "commission", partner: true },
    { id: "runway", name: "Runway", icon: "🎬", color: "#ef4444", category: "video", difficulty: 3, incomeMin: 6000, incomeMax: 20000, tier: "commission", partner: true },
    { id: "dalle3", name: "DALL-E 3", icon: "🖼️", color: "#8b5cf6", category: "art", difficulty: 2, incomeMin: 4000, incomeMax: 12000, tier: "private" },
    { id: "perplexity", name: "Perplexity", icon: "🔍", color: "#14b8a6", category: "research", difficulty: 1, incomeMin: 2500, incomeMax: 7000, tier: "commission", partner: true },
    { id: "copilot", name: "GitHub Copilot", icon: "👨‍💻", color: "#3b82f6", category: "code", difficulty: 4, incomeMin: 8000, incomeMax: 25000, tier: "private" },
    { id: "gamma", name: "Gamma", icon: "📊", color: "#ec4899", category: "productivity", difficulty: 1, incomeMin: 3000, incomeMax: 9000, tier: "commission", partner: true },
    { id: "claudecode", name: "Claude Code", icon: "💻", color: "#f97316", category: "code", difficulty: 4, incomeMin: 10000, incomeMax: 30000, tier: "private" }
  ];
  
  function getTrendingTools() {
    return [...toolDatabase].sort((a, b) => b.incomeMax - a.incomeMax).slice(0, 4);
  }
  
  function getBeginnerTools() {
    return toolDatabase.filter(t => t.difficulty <= 2).sort((a, b) => b.incomeMax - a.incomeMax).slice(0, 4);
  }
  
  function getPassiveTools() {
    const passiveCats = ['art', 'productivity', 'research'];
    return toolDatabase.filter(t => passiveCats.includes(t.category)).sort((a, b) => b.incomeMax - a.incomeMax).slice(0, 4);
  }
  
  function getPersonalizedTools() {
    const viewed = JSON.parse(localStorage.getItem('viewedTools') || '[]');
    if (viewed.length === 0) return getTrendingTools();
    const viewedCats = viewed.map(id => toolDatabase.find(t => t.id === id)?.category).filter(Boolean);
    const uniqueCats = [...new Set(viewedCats)];
    return toolDatabase.filter(t => !viewed.includes(t.id) && uniqueCats.includes(t.category)).slice(0, 4);
  }
  
  function renderRecommendationCard(tool, reason) {
    const badge = tool.tier === 'commission' ? '<span class="partner-badge-small">💰 Partner</span>' : '';
    const btnText = tool.tier === 'commission' ? 'Try Free' : 'Unlock Guide';
    const btnClass = tool.tier === 'commission' ? 'btn-urgent' : 'btn-primary';
    return `
      <div class="recommendation-card" data-tool-id="${tool.id}">
        <span class="rec-badge">${reason}</span>
        <div class="rec-header">
          <div class="rec-icon" style="background: ${tool.color}20; color: ${tool.color}">${tool.icon}</div>
          <div class="rec-info">
            <h3>${tool.name}</h3>
            <span class="rec-category">${tool.category}</span>
          </div>
        </div>
        <div class="rec-income">$${tool.incomeMin.toLocaleString()}-$${tool.incomeMax.toLocaleString()}/mo</div>
        <div class="rec-reason">${getRecommendationReason(tool)}</div>
        <div class="rec-actions">
          <a href="/tool/${tool.id}/" class="btn ${btnClass}">${btnText}</a>
          ${badge}
        </div>
      </div>
    `;
  }
  
  function getRecommendationReason(tool) {
    if (tool.difficulty === 1) return "✨ Perfect for beginners - start earning today!";
    if (tool.incomeMax > 15000) return "🚀 High income potential - top earners choice!";
    if (tool.tier === 'commission') return "💎 Partner tool - exclusive perks included!";
    return "💡 Popular choice among successful users";
  }
  
  function loadRecommendations(type) {
    const grid = document.getElementById('recommendations-grid');
    if (!grid) return;
    
    let tools = [];
    let reason = "";
    
    switch(type) {
      case 'trending':
        tools = getTrendingTools();
        reason = "🔥 Hot";
        break;
      case 'beginner':
        tools = getBeginnerTools();
        reason = "🌱 Easy";
        break;
      case 'passive':
        tools = getPassiveTools();
        reason = "💤 Passive";
        break;
      case 'similar':
        tools = getPersonalizedTools();
        reason = "💡 For You";
        break;
    }
    
    grid.innerHTML = tools.map(t => renderRecommendationCard(t, reason)).join('');
  }
  
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      loadRecommendations(this.dataset.tab);
    });
  });
  
  // Load initial recommendations
  document.addEventListener('DOMContentLoaded', () => {
    loadRecommendations('trending');
  });
  
  // Track tool views
  document.querySelectorAll('.tool-card, .recommendation-card').forEach(card => {
    card.addEventListener('click', () => {
      const toolId = card.dataset.toolId;
      if (toolId) {
        const viewed = JSON.parse(localStorage.getItem('viewedTools') || '[]');
        if (!viewed.includes(toolId)) {
          viewed.push(toolId);
          localStorage.setItem('viewedTools', JSON.stringify(viewed));
        }
        // Update user profile
        updateUserProfile(toolId);
      }
    });
  });
  
  // Advanced User Profile System
  function updateUserProfile(toolId) {
    const tool = toolDatabase.find(t => t.id === toolId);
    if (!tool) return;
    
    let profile = JSON.parse(localStorage.getItem('userProfile') || '{}');
    
    // Initialize profile if empty
    if (!profile.categories) profile.categories = {};
    if (!profile.difficultyPreference) profile.difficultyPreference = [];
    if (!profile.incomeInterest) profile.incomeInterest = [];
    if (!profile.visitCount) profile.visitCount = 0;
    if (!profile.lastVisit) profile.lastVisit = null;
    
    // Update category interest
    profile.categories[tool.category] = (profile.categories[tool.category] || 0) + 1;
    
    // Update difficulty preference
    profile.difficultyPreference.push(tool.difficulty);
    if (profile.difficultyPreference.length > 10) {
      profile.difficultyPreference.shift();
    }
    
    // Update income interest
    profile.incomeInterest.push(tool.incomeMax);
    if (profile.incomeInterest.length > 10) {
      profile.incomeInterest.shift();
    }
    
    // Update visit stats
    profile.visitCount++;
    profile.lastVisit = new Date().toISOString();
    
    // Calculate user type
    profile.userType = calculateUserType(profile);
    
    localStorage.setItem('userProfile', JSON.stringify(profile));
  }
  
  function calculateUserType(profile) {
    const avgDifficulty = profile.difficultyPreference.reduce((a, b) => a + b, 0) / profile.difficultyPreference.length;
    const avgIncome = profile.incomeInterest.reduce((a, b) => a + b, 0) / profile.incomeInterest.length;
    
    if (avgDifficulty <= 1.5 && avgIncome < 8000) return 'beginner';
    if (avgDifficulty >= 3 && avgIncome > 15000) return 'advanced';
    if (avgIncome > 20000) return 'ambitious';
    return 'balanced';
  }
  
  function getSmartRecommendations() {
    const profile = JSON.parse(localStorage.getItem('userProfile') || '{}');
    const viewed = JSON.parse(localStorage.getItem('viewedTools') || '[]');
    
    if (!profile.categories || Object.keys(profile.categories).length === 0) {
      return getTrendingTools();
    }
    
    // Find top category
    const topCategory = Object.entries(profile.categories)
      .sort((a, b) => b[1] - a[1])[0][0];
    
    // Calculate average difficulty preference
    const avgDifficulty = profile.difficultyPreference.reduce((a, b) => a + b, 0) / profile.difficultyPreference.length;
    
    // Score all unviewed tools
    let scoredTools = toolDatabase
      .filter(t => !viewed.includes(t.id))
      .map(tool => {
        let score = 0;
        
        // Category match (highest weight)
        if (tool.category === topCategory) score += 50;
        
        // Difficulty match
        const diffDiff = Math.abs(tool.difficulty - avgDifficulty);
        score += Math.max(0, 30 - diffDiff * 10);
        
        // Income potential
        score += (tool.incomeMax / 1000) * 2;
        
        // User type bonus
        if (profile.userType === 'beginner' && tool.difficulty <= 2) score += 20;
        if (profile.userType === 'advanced' && tool.difficulty >= 3) score += 20;
        if (profile.userType === 'ambitious' && tool.incomeMax > 15000) score += 25;
        
        return { ...tool, score };
      });
    
    return scoredTools.sort((a, b) => b.score - a.score).slice(0, 4);
  }
  
  // Add smart recommendations tab
  document.addEventListener('DOMContentLoaded', () => {
    // Add Smart tab if user has profile
    const profile = JSON.parse(localStorage.getItem('userProfile') || '{}');
    if (profile.categories && Object.keys(profile.categories).length > 0) {
      const tabsContainer = document.querySelector('.recommendation-tabs');
      if (tabsContainer) {
        const smartTab = document.createElement('button');
        smartTab.className = 'tab-btn';
        smartTab.dataset.tab = 'smart';
        smartTab.innerHTML = '🎯 Smart Match';
        tabsContainer.appendChild(smartTab);
        
        smartTab.addEventListener('click', function() {
          document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          this.classList.add('active');
          const tools = getSmartRecommendations();
          const grid = document.getElementById('recommendations-grid');
          grid.innerHTML = tools.map(t => renderRecommendationCard(t, '🎯 Best Match')).join('');
        });
      }
    }
  });
  
  // Learning Progress Tracker
  function updateProgressDisplay() {
    const profile = JSON.parse(localStorage.getItem('userProfile') || '{}');
    const viewed = JSON.parse(localStorage.getItem('viewedTools') || '[]');
    
    // Update stats
    document.getElementById('tools-viewed').textContent = viewed.length;
    
    const categories = profile.categories ? Object.keys(profile.categories).length : 0;
    document.getElementById('categories-tried').textContent = categories;
    
    // Calculate level
    let level = 'Beginner';
    let milestone = 5;
    let progress = 0;
    
    if (viewed.length >= 10 && categories >= 4) {
      level = 'Master';
      milestone = 'Max';
      progress = 100;
    } else if (viewed.length >= 7 && categories >= 3) {
      level = 'Expert';
      milestone = 10;
      progress = 75;
    } else if (viewed.length >= 5 && categories >= 2) {
      level = 'Advanced';
      milestone = 7;
      progress = 50;
    } else if (viewed.length >= 3 && categories >= 1) {
      level = 'Intermediate';
      milestone = 5;
      progress = 25;
    }
    
    document.getElementById('user-level').textContent = level;
    document.getElementById('next-milestone').textContent = milestone;
    document.getElementById('progress-fill').style.width = progress + '%';
    
    // Update achievements
    if (viewed.length >= 3) unlockAchievement('badge-explorer');
    if (categories >= 2) unlockAchievement('badge-curious');
    if (viewed.length >= 5) unlockAchievement('badge-learner');
    if (categories >= 4) unlockAchievement('badge-master');
    
    // Update progress text
    const texts = [
      "Start exploring tools to earn your first badge!",
      "Great start! Keep exploring to unlock more badges.",
      "You're making progress! Try different categories.",
      "Almost there! You're becoming an AI expert.",
      "Congratulations! You're a Master of AI tools!"
    ];
    const textIndex = Math.min(Math.floor(progress / 25), 4);
    document.getElementById('progress-text').textContent = texts[textIndex];
  }
  
  function unlockAchievement(id) {
    const badge = document.getElementById(id);
    if (badge && badge.dataset.locked === 'true') {
      badge.dataset.locked = 'false';
      badge.classList.add('unlocked');
      badge.querySelector('.achievement-icon').textContent += ' ✓';
    }
  }
  
  // Initialize progress on load
  document.addEventListener('DOMContentLoaded', () => {
    updateProgressDisplay();
    
    // Show floating CTA after scrolling
    const floatingCta = document.getElementById('floating-cta');
    if (floatingCta) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 500) {
          floatingCta.classList.add('visible');
        } else {
          floatingCta.classList.remove('visible');
        }
      });
    }
  });
  
  // Update progress when tools are clicked
  document.querySelectorAll('.tool-card, .recommendation-card').forEach(card => {
    card.addEventListener('click', () => {
      setTimeout(updateProgressDisplay, 100);
    });
  });
</script>

