---
import Layout from '../../layouts/Layout.astro';
const title = "Asset Digitali AI Premium | AIToolGuide";
---

<Layout title={title}>
  <div class="page">
    <div class="container">
      <div class="lang-bar">
        <a href="/domains" class="lang-btn">EN</a>
        <a href="/domains/zh" class="lang-btn">中文</a>
        <a href="/domains/fr" class="lang-btn">FR</a>
        <a href="/domains/de" class="lang-btn">DE</a>
        <a href="/domains/it" class="lang-btn active">IT</a>
        <a href="/domains/es" class="lang-btn">ES</a>
      </div>
      <h1>Asset Digitali AI Premium</h1>
      <p class="subtitle">Un portfolio curato di identità ad alta autorità per infrastrutture AI di nuova generazione.</p>
      <div class="grid">
        <a href="/domain/ai860" class="card">
          <div class="card-header"><h2>ai860.com</h2><span class="tag">Core Globale</span></div>
          <p>Infrastruttura premium 3 cifre. L'ultimo gateway commerciale.</p>
          <div class="card-footer"><span class="view">Vedi Dettagli →</span><span>|</span><span class="grade">Grado Istituzionale</span></div>
        </a>
        <a href="/domain/ai960" class="card">
          <div class="card-header"><h2>ai960.com</h2><span class="tag">Potenza Regionale</span></div>
          <p>Narrativa strategica 960M km². Top-tier per giganti AI regionali.</p>
          <div class="card-footer"><span class="view">Vedi Dettagli →</span><span>|</span><span class="grade">Grado Istituzionale</span></div>
        </a>
        <a href="/domain/ai8880" class="card">
          <div class="card-header"><h2>ai8880.com</h2><span class="tag">Prestigio</span></div>
          <p>Prefisso triple-8 fortuna. Impatto elevato per mercati asiatici.</p>
          <div class="card-footer"><span class="view">Vedi Dettagli →</span><span>|</span><span class="grade">Grado Istituzionale</span></div>
        </a>
        <a href="/domain/ai9998" class="card">
          <div class="card-header"><h2>ai9998.com</h2><span class="tag">Autorità</span></div>
          <p>Sequenza numerica suprema. Identità imperiale per leader AI.</p>
          <div class="card-footer"><span class="view">Vedi Dettagli →</span><span>|</span><span class="grade">Grado Istituzionale</span></div>
        </a>
        <a href="/domain/ai617" class="card">
          <div class="card-header"><h2>ai617.com</h2><span class="tag">Accademico</span></div>
          <p>L'eredità di Boston. Collegamento diretto con MIT, Harvard & Cambridge.</p>
          <div class="card-footer"><span class="view">Vedi Dettagli →</span><span>|</span><span class="grade">Grado Istituzionale</span></div>
        </a>
        <a href="/domain/ai271" class="card">
          <div class="card-header"><h2>ai271.com</h2><span class="tag">Deep Tech</span></div>
          <p>Numero di Eulero (e). Fondamento matematico delle reti neurali.</p>
          <div class="card-footer"><span class="view">Vedi Dettagli →</span><span>|</span><span class="grade">Grado Istituzionale</span></div>
        </a>
        <a href="/domain/ai264" class="card">
          <div class="card-header"><h2>ai264.com</h2><span class="tag">Standard Industria</span></div>
          <p>Eredità codifica video. AI generativa next-gen.</p>
          <div class="card-footer"><span class="view">Vedi Dettagli →</span><span>|</span><span class="grade">Grado Istituzionale</span></div>
        </a>
        <a href="/domain/ai2424" class="card">
          <div class="card-header"><h2>ai2424.com</h2><span class="tag">Agentico</span></div>
          <p>Autonomia 24/7. Progettato per Agenti AI & SaaS automatizzati.</p>
          <div class="card-footer"><span class="view">Vedi Dettagli →</span><span>|</span><span class="grade">Grado Istituzionale</span></div>
        </a>
      </div>
    </div>
  </div>
  <style>
    .page { background: #0b0b0b; min-height: 100vh; color: #fff; }
    .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }
    .lang-bar { display: flex; justify-content: flex-end; gap: 8px; margin-bottom: 40px; }
    .lang-btn { padding: 8px 16px; background: transparent; color: #666; border: 1px solid #333; border-radius: 4px; font-size: 12px; text-decoration: none; transition: all 0.2s; }
    .lang-btn:hover { border-color: #555; color: #999; }
    .lang-btn.active { background: #fff; color: #0b0b0b; border-color: #fff; }
    h1 { font-size: 42px; font-weight: 700; margin-bottom: 16px; }
    .subtitle { color: #888; font-size: 16px; max-width: 600px; margin-bottom: 60px; }
    .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    @media (max-width: 768px) { .grid { grid-template-columns: 1fr; } }
    .card { display: block; background: #000; border: 1px solid #333; border-radius: 8px; padding: 32px; text-decoration: none; color: inherit; transition: border-color 0.2s; }
    .card:hover { border-color: #666; }
    .card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
    .card h2 { font-family: 'SF Mono', monospace; font-size: 24px; font-weight: 700; color: #fff; margin: 0; }
    .tag { font-size: 11px; color: #888; background: #1a1a1a; padding: 6px 12px; border-radius: 4px; letter-spacing: 0.1em; text-transform: uppercase; border: 1px solid #333; }
    .card > p { color: #666; font-size: 14px; line-height: 1.6; margin-bottom: 24px; }
    .card-footer { display: flex; align-items: center; gap: 12px; }
    .view { font-size: 12px; color: #fff; border-bottom: 1px solid #fff; padding-bottom: 2px; }
    .card-footer span:nth-child(2) { color: #444; }
    .grade { font-size: 12px; color: #555; font-style: italic; }
  </style>
</Layout>
