---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="AI Writing & Copywriting - Make Money with AI">
  <div class="category-page">
    <header class="category-header">
      <div class="container">
        <span class="category-icon">✍️</span>
        <h1>AI Writing & Copywriting</h1>
        <p>Use AI tools to provide copywriting, content creation, and ghostwriting services</p>
        <div class="income-badge">💰 $500-2,000/month</div>
      </div>
    </header>

    <section class="tools-section">
      <div class="container">
        <h2>Recommended Tools</h2>
        <div class="tools-grid">
          <a href="/tool/chatgpt/" class="tool-card">
            <h3>ChatGPT</h3>
            <p class="income">$500-1,500/month</p>
            <p class="difficulty">Difficulty: ⭐⭐</p>
            <span class="btn">View Tutorial →</span>
          </a>
          <a href="/tool/claude/" class="tool-card">
            <h3>Claude</h3>
            <p class="income">$700-2,000/month</p>
            <p class="difficulty">Difficulty: ⭐⭐</p>
            <span class="btn">View Tutorial →</span>
          </a>
          <a href="/tool/notion/" class="tool-card">
            <h3>Notion AI</h3>
            <p class="income">$300-1,000/month</p>
            <p class="difficulty">Difficulty: ⭐</p>
            <span class="btn">View Tutorial →</span>
          </a>
        </div>
      </div>
    </section>

    <section class="methods-section">
      <div class="container">
        <h2>Money Making Methods</h2>
        <ul class="methods-list">
          <li>Copywriting services for social media</li>
          <li>Ghostwriting articles and blog posts</li>
          <li>Resume optimization services</li>
          <li>Academic writing assistance</li>
          <li>Short video script writing</li>
        </ul>
      </div>
    </section>

    <!-- Getting Started Steps -->
    <section class="steps-section">
      <div class="container">
        <h2>Getting Started in 4 Steps</h2>
        <div class="steps-grid">
          <div class="step-card">
            <span class="step-num">1</span>
            <h3>Choose Your Tool</h3>
            <p>Start with ChatGPT (free) or Claude. Experiment with writing different types of content.</p>
          </div>
          <div class="step-card">
            <span class="step-num">2</span>
            <h3>Build Portfolio</h3>
            <p>Create 5-10 sample pieces. Write blog posts, social content, and sales copy samples.</p>
          </div>
          <div class="step-card">
            <span class="step-num">3</span>
            <h3>Join Platforms</h3>
            <p>Sign up on Upwork, Fiverr, and Freelancer. Complete your profile with portfolio links.</p>
          </div>
          <div class="step-card">
            <span class="step-num">4</span>
            <h3>Land First Client</h3>
            <p>Apply to 20+ jobs daily. Start with $20-50 projects to get reviews, then increase rates.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Success Story -->
    <section class="story-section">
      <div class="container">
        <h2>Success Story</h2>
        <div class="story-card">
          <div class="story-header">
            <span class="story-income">$1,200/month</span>
            <span class="story-tag">Beginner Friendly</span>
          </div>
          <h3>College Student Pays Tuition with ChatGPT Writing</h3>
          <p>Sarah, a university student, started using ChatGPT to help classmates with essays and assignments. Within 2 months, she was earning $1,200/month part-time, enough to cover her tuition and living expenses.</p>
          <div class="story-meta">
            <span>⏱️ Started: 2 months ago</span>
            <span>📝 Projects: 50+ completed</span>
            <span>⭐ Rating: 4.9/5</span>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
          <div class="faq-item">
            <h4>Do I need to be a good writer?</h4>
            <p>No! AI tools do the heavy lifting. You just need to guide them and edit the output.</p>
          </div>
          <div class="faq-item">
            <h4>How fast can I start earning?</h4>
            <p>Most people land their first client within 3-7 days of starting.</p>
          </div>
          <div class="faq-item">
            <h4>Is this ethical?</h4>
            <p>Yes, as long as you're transparent with clients and deliver quality work. Many businesses specifically want AI-assisted content.</p>
          </div>
          <div class="faq-item">
            <h4>What if I don't have experience?</h4>
            <p>Start with simple projects and build your portfolio. Everyone starts somewhere!</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container">
        <h2>Ready to Start Earning?</h2>
        <p>Join thousands of people already making money with AI writing tools</p>
        <div class="cta-buttons">
          <a href="/tool/chatgpt/" class="btn btn-primary btn-large">Start with ChatGPT →</a>
          <a href="/vip-methods/" class="btn btn-secondary btn-large">View Advanced Methods</a>
        </div>
        <p class="cta-note">🎁 First 100 users get free AI Writing Toolkit</p>
      </div>
    </section>
  </div>

  <style>
    .category-page { padding-top: 100px; }
    .category-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 60px 0;
      text-align: center;
    }
    .category-icon { font-size: 4rem; display: block; margin-bottom: 20px; }
    .category-header h1 { font-size: 2.5rem; margin-bottom: 16px; }
    .income-badge {
      display: inline-block;
      background: rgba(255,255,255,0.2);
      padding: 12px 24px;
      border-radius: 30px;
      margin-top: 20px;
      font-weight: 700;
    }
    .tools-section, .methods-section { padding: 60px 0; }
    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 24px;
      margin-top: 30px;
    }
    .tool-card {
      background: white;
      border: 2px solid #e2e8f0;
      border-radius: 16px;
      padding: 24px;
      text-decoration: none;
      color: inherit;
      transition: all 0.3s;
    }
    .tool-card:hover {
      border-color: #667eea;
      transform: translateY(-4px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    .tool-card h3 { font-size: 1.5rem; margin-bottom: 12px; }
    .tool-card .income { color: #059669; font-weight: 600; margin-bottom: 8px; }
    .tool-card .difficulty { color: #64748b; margin-bottom: 16px; }
    .tool-card .btn {
      display: inline-block;
      padding: 10px 20px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border-radius: 8px;
      font-weight: 600;
    }
    .methods-list {
      list-style: none;
      max-width: 600px;
      margin: 30px auto 0;
    }
    .methods-list li {
      padding: 16px 20px;
      background: #f8fafc;
      border-radius: 12px;
      margin-bottom: 12px;
      font-size: 1.1rem;
    }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    h2 { text-align: center; font-size: 2rem; margin-bottom: 10px; }
    
    /* New Sections */
    .steps-section, .story-section, .faq-section, .cta-section { padding: 60px 0; }
    .steps-section { background: #f8fafc; }
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 24px;
      margin-top: 40px;
    }
    .step-card {
      background: white;
      padding: 30px;
      border-radius: 16px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05);
      text-align: center;
    }
    .step-num {
      width: 50px;
      height: 50px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-weight: 700;
      margin: 0 auto 20px;
    }
    .step-card h3 { font-size: 1.3rem; margin-bottom: 12px; }
    .step-card p { color: #64748b; }
    
    .story-card {
      max-width: 800px;
      margin: 40px auto 0;
      background: white;
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    }
    .story-header {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
    }
    .story-income {
      background: linear-gradient(135deg, #fef3c7, #fde68a);
      color: #92400e;
      padding: 8px 16px;
      border-radius: 20px;
      font-weight: 700;
    }
    .story-tag {
      background: linear-gradient(135deg, #dbeafe, #e0e7ff);
      color: #1e40af;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 0.9rem;
    }
    .story-card h3 { font-size: 1.5rem; margin-bottom: 16px; }
    .story-card > p { color: #475569; line-height: 1.8; margin-bottom: 20px; }
    .story-meta {
      display: flex;
      gap: 24px;
      color: #64748b;
      font-size: 0.9rem;
    }
    
    .faq-section { background: #f8fafc; }
    .faq-list {
      max-width: 800px;
      margin: 40px auto 0;
    }
    .faq-item {
      background: white;
      padding: 24px;
      border-radius: 12px;
      margin-bottom: 16px;
    }
    .faq-item h4 { font-size: 1.1rem; margin-bottom: 12px; color: #1e293b; }
    .faq-item p { color: #64748b; }
    
    .cta-section {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      text-align: center;
    }
    .cta-section h2 { color: white; margin-bottom: 16px; }
    .cta-section > p { font-size: 1.2rem; opacity: 0.9; margin-bottom: 32px; }
    .cta-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }
    .btn-large { padding: 16px 32px; font-size: 1.1rem; }
    .btn-secondary {
      background: white;
      color: #667eea;
    }
    .cta-note {
      opacity: 0.8;
      font-size: 0.95rem;
    }
    
    @media (max-width: 768px) {
      .steps-grid { grid-template-columns: 1fr; }
      .cta-buttons { flex-direction: column; align-items: center; }
      .story-meta { flex-direction: column; gap: 8px; }
    }
  </style>
</Layout>
