---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="AI Productivity - Make Money with AI">
  <div class="category-page">
    <header class="category-header" style="background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);">
      <div class="container">
        <span class="category-icon">⚡</span>
        <h1>AI Productivity</h1>
        <p>Automate workflows, boost efficiency, and save time with AI productivity tools</p>
        <div class="income-badge">💰 $300-2,000/month</div>
      </div>
    </header>

    <section class="tools-section">
      <div class="container">
        <h2>Recommended Tools</h2>
        <div class="tools-grid">
          <a href="/tool/perplexity/" class="tool-card">
            <h3>Perplexity</h3>
            <p class="income">$300-1,500/month</p>
            <p class="difficulty">Difficulty: ⭐</p>
            <span class="btn">View Tutorial →</span>
          </a>
          <a href="/tool/gamma/" class="tool-card">
            <h3>Gamma</h3>
            <p class="income">$400-2,000/month</p>
            <p class="difficulty">Difficulty: ⭐⭐</p>
            <span class="btn">View Tutorial →</span>
          </a>
        </div>
      </div>
    </section>

    <section class="methods-section">
      <div class="container">
        <h2>Money Making Methods</h2>
        <ul class="methods-list">
          <li>Research and report writing services</li>
          <li>Business process automation</li>
          <li>Data analysis and visualization</li>
          <li>Presentation and pitch deck creation</li>
          <li>Virtual assistant services</li>
        </ul>
      </div>
    </section>
  </div>

  <style>
    .category-page { padding-top: 100px; }
    .category-header { color: #1e293b; padding: 60px 0; text-align: center; }
    .category-icon { font-size: 4rem; display: block; margin-bottom: 20px; }
    .category-header h1 { font-size: 2.5rem; margin-bottom: 16px; }
    .income-badge { display: inline-block; background: rgba(255,255,255,0.5); padding: 12px 24px; border-radius: 30px; margin-top: 20px; font-weight: 700; }
    .tools-section, .methods-section { padding: 60px 0; }
    .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; margin-top: 30px; }
    .tool-card { background: white; border: 2px solid #e2e8f0; border-radius: 16px; padding: 24px; text-decoration: none; color: inherit; transition: all 0.3s; }
    .tool-card:hover { border-color: #fcb69f; transform: translateY(-4px); box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
    .tool-card h3 { font-size: 1.5rem; margin-bottom: 12px; }
    .tool-card .income { color: #059669; font-weight: 600; margin-bottom: 8px; }
    .tool-card .difficulty { color: #64748b; margin-bottom: 16px; }
    .tool-card .btn { display: inline-block; padding: 10px 20px; background: linear-gradient(135deg, #ffecd2, #fcb69f); color: #1e293b; border-radius: 8px; font-weight: 600; }
    .methods-list { list-style: none; max-width: 600px; margin: 30px auto 0; }
    .methods-list li { padding: 16px 20px; background: #f8fafc; border-radius: 12px; margin-bottom: 12px; font-size: 1.1rem; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    h2 { text-align: center; font-size: 2rem; margin-bottom: 10px; }
  </style>
</Layout>
