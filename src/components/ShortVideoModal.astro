---
// Short Video Landing Modal Component
// Triggered when user comes from short video platforms
---

<div id="shortVideoModal" class="modal" style="display: none;">
  <div class="modal-overlay" onclick="closeShortModal()"></div>
  <div class="modal-content short-modal">
    <button class="modal-close" onclick="closeShortModal()">×</button>
    
    <div class="short-modal-header">
      <span class="short-modal-emoji">🎁</span>
      <h2 class="short-modal-title">Welcome from TikTok!</h2>
      <p class="short-modal-subtitle">Get your FREE AI Money Toolkit</p>
    </div>
    
    <div class="short-modal-body">
      <div class="short-modal-gift">
        <div class="gift-item">
          <span class="gift-icon">📚</span>
          <span class="gift-text">100 AI Tools with Income Guides</span>
        </div>
        <div class="gift-item">
          <span class="gift-icon">💰</span>
          <span class="gift-text">Real $500-$5000/Month Case Studies</span>
        </div>
        <div class="gift-item">
          <span class="gift-icon">🚀</span>
          <span class="gift-text">Step-by-Step Video Tutorials</span>
        </div>
        <div class="gift-item">
          <span class="gift-icon">🔥</span>
          <span class="gift-text">Exclusive Freelance Job Channels</span>
        </div>
      </div>
      
      <form class="short-modal-form" onsubmit="handleShortSubmit(event)">
        <input 
          type="email" 
          id="shortEmail" 
          class="short-modal-input" 
          placeholder="Enter your email" 
          required
        />
        <button type="submit" class="short-modal-btn">
          <span>Get FREE Toolkit →</span>
        </button>
      </form>
      
      <p class="short-modal-note">
        🔒 No spam. Unsubscribe anytime. 50,000+ people already joined.
      </p>
    </div>
  </div>
</div>

<style>
  .modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }
  
  .modal-content {
    position: relative;
    background: #0a0a0a;
    border: 1px solid #333;
    border-radius: 16px;
    padding: 32px;
    max-width: 480px;
    width: 90%;
    z-index: 1001;
    animation: modalSlideIn 0.3s ease;
  }
  
  @keyframes modalSlideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: #666;
    font-size: 24px;
    cursor: pointer;
    transition: color 0.2s;
  }
  
  .modal-close:hover {
    color: #fff;
  }
  
  .short-modal-header {
    text-align: center;
    margin-bottom: 24px;
  }
  
  .short-modal-emoji {
    font-size: 48px;
    display: block;
    margin-bottom: 12px;
  }
  
  .short-modal-title {
    font-size: 24px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }
  
  .short-modal-subtitle {
    font-size: 16px;
    color: #888;
  }
  
  .short-modal-gift {
    background: #111;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
  }
  
  .gift-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid #222;
  }
  
  .gift-item:last-child {
    border-bottom: none;
  }
  
  .gift-icon {
    font-size: 20px;
  }
  
  .gift-text {
    font-size: 14px;
    color: #ccc;
  }
  
  .short-modal-form {
    margin-bottom: 16px;
  }
  
  .short-modal-input {
    width: 100%;
    padding: 14px 16px;
    background: #111;
    border: 1px solid #333;
    border-radius: 8px;
    color: #fff;
    font-size: 16px;
    margin-bottom: 12px;
    transition: border-color 0.2s;
  }
  
  .short-modal-input:focus {
    outline: none;
    border-color: #635bff;
  }
  
  .short-modal-input::placeholder {
    color: #555;
  }
  
  .short-modal-btn {
    width: 100%;
    padding: 14px 24px;
    background: linear-gradient(135deg, #635bff, #8b5cf6);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  
  .short-modal-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(99, 91, 255, 0.3);
  }
  
  .short-modal-note {
    text-align: center;
    font-size: 12px;
    color: #555;
  }
</style>

<script is:inline>
  // Check if user came from short video
  function checkShortVideoSource() {
    const urlParams = new URLSearchParams(window.location.search);
    const source = urlParams.get('utm_source');
    const ref = urlParams.get('ref');
    
    // Show modal if from short video platforms
    if (source === 'short' || source === 'tiktok' || source === 'video' || ref === 'short') {
      // Delay slightly for better UX
      setTimeout(() => {
        showShortModal();
      }, 1500);
      
      // Store in session
      sessionStorage.setItem('fromShortVideo', 'true');
    }
  }
  
  function showShortModal() {
    const modal = document.getElementById('shortVideoModal');
    if (modal) {
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      
      // Track event
      if (typeof gtag !== 'undefined') {
        gtag('event', 'short_video_modal_show');
      }
    }
  }
  
  function closeShortModal() {
    const modal = document.getElementById('shortVideoModal');
    if (modal) {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }
  }
  
  function handleShortSubmit(e) {
    e.preventDefault();
    const email = document.getElementById('shortEmail').value;
    
    // Store email
    localStorage.setItem('userEmail', email);
    localStorage.setItem('fromShortVideo', 'true');
    
    // Track conversion
    if (typeof gtag !== 'undefined') {
      gtag('event', 'short_video_email_submit', {
        'event_category': 'conversion',
        'event_label': 'short_video_modal'
      });
    }
    
    // Show success message
    alert('🎉 Check your email! We\'ve sent you the AI Money Toolkit.');
    closeShortModal();
    
    // Redirect to tools section
    window.location.href = '/#tools';
  }
  
  // Run on page load
  document.addEventListener('DOMContentLoaded', checkShortVideoSource);
</script>
