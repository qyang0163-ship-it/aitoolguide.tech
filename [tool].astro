      }
    ],
    platforms: [
      { name: '小红书', desc: '展示作品，吸引客户', link: '#' },
      { name: '闲鱼', desc: '接单平台，门槛低', link: '#' },
      { name: '猪八戒', desc: '设计订单多', link: '#' },
      { name: '微信表情', desc: '表情包变现', link: '#' }
    ],
    tips: [
      '多练习Prompt，提升出图质量',
      '建立自己的风格，形成差异化',
      '学会基础PS，提升交付质量',
      '重视客户反馈，持续优化'
    ],
    faq: [
      { q: 'Midjourney订阅费用多少？', a: '标准版$30/月，足够接单使用' },
      { q: '不会PS能做吗？', a: '可以，但会PS能接更高单价订单' },
