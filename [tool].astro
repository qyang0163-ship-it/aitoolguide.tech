      { name: '闲鱼', desc: '门槛低，适合新手', link: '#' },
      { name: '猪八戒', desc: '订单多，竞争激烈', link: '#' },
      { name: '小红书', desc: '流量大，适合引流', link: '#' },
      { name: '淘宝', desc: '信誉度高，长期稳定', link: '#' }
    ],
    tips: [
      '学会写高质量Prompt是关键',
      '不要直接复制AI内容，要人工润色',
      '建立自己的客户群体，减少平台依赖',
      '多学习营销技巧，提高客单价'
    ],
    faq: [
      { q: '需要购买ChatGPT Plus吗？', a: '建议购买，GPT-4质量更高，能接更高单价订单' },
      { q: '新手多久能赚钱？', a: '一般1-3天就能接到第一单' },
      { q: '会被客户发现用AI吗？', a: '只要人工润色到位，客户通常看不出来' }
    ]
  },
  'midjourney': {
    name: 'Midjourney',
    icon: '🎨',
    color: '#6366f1',
    category: 'AI绘画接单',
    headline: 'Midjourney怎么赚钱？2026年实测月入15000+的4种方法',
    description: 'Midjourney是目前最强大的AI绘画工具，用它能轻松接设计单赚钱',
    income: '￥5000-15000/月',
    difficulty: '⭐⭐⭐',
    timeToFirstIncome: '3-7天',
    tools: ['Midjourney订阅', 'Discord账号', '设计软件（PS/AI）'],
    methods: [
      {
        title: '头像定制服务',
        desc: '帮客户生成个性化AI头像、情侣头像',
        steps: ['在小红书/闲鱼发布作品', '吸引客户咨询', '根据需求生成头像', '精修后交付'],
        income: '￥30-100/张',
        tip: '重点：展示作品集，建立信任'
      },
      {
        title: '电商设计接单',
        desc: '做产品主图、详情页、海报设计',
        steps: ['加入电商设计群', '展示AI作品案例', '接单并按需求生成', '结合PS精修'],
