// 生成静态路径
export function getStaticPaths() {
  return Object.keys(toolDetails).map(tool => ({
    params: { tool }
  }));
}

const { tool } = Astro.params;
const toolData = toolDetails[tool] || toolDetails['chatgpt'];
---

<Layout title={`${toolData.name}赚钱攻略 - ${toolData.headline}`}>
  <!-- 紧迫感横幅 -->
  <div class="urgency-banner">
    🔥 限时福利：前100名注册用户可获得《{toolData.name}赚钱工具包》+ 独家接单渠道
  </div>

  <!-- Header -->
  <header class="header">
    <div class="container">
      <nav class="nav">
        <a href="/" class="logo">
          <span class="logo-icon">💰</span>
          <span class="logo-text">AIToolGuide</span>
          <span class="logo-tag">赚钱版</span>
        </a>
        <div class="nav-links">
          <a href="/">首页</a>
          <a href="/#tools">赚钱工具</a>
          <a href="/#methods">变现方法</a>
          <a href="/#stories">成功案例</a>
        </div>
        <a href={toolData.url || '#'} target="_blank" class="btn btn-primary btn-small">免费使用{toolData.name} →</a>
      </nav>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero" style={`background: linear-gradient(135deg, ${toolData.color}10, ${toolData.color}05);`}>
    <div class="container">
      <div class="hero-content">
        <div class="tool-badge" style={`background: ${toolData.color}20; color: ${toolData.color}`}>
          <span class="tool-icon-large">{toolData.icon}</span>
          <span>{toolData.category}</span>
        </div>
        <h1 class="hero-title">{toolData.headline}</h1>
        <p class="hero-description">{toolData.description}</p>
        
        <div class="hero-stats">
          <div class="stat-card">
            <span class="stat-value">{toolData.income}</span>
            <span class="stat-label">预期收入</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">{toolData.difficulty}</span>
            <span class="stat-label">上手难度</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">{toolData.timeToFirstIncome}</span>
            <span class="stat-label">首单时间</span>
          </div>
        </div>
        
        <div class="hero-actions">
          <a href="#methods" class="btn btn-urgent btn-large">🔥 立即学习赚钱方法</a>
          <a href={toolData.url || '#'} target="_blank" class="btn btn-primary btn-large">💎 免费使用{toolData.name}</a>
          <a href="#platforms" class="btn btn-secondary btn-large">📱 查看接单平台</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 所需工具 -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">🛠️ 准备工作</span>
        <h2 class="section-title">你需要准备这些</h2>
      </div>
      <div class="tools-needed">
        {toolData.tools.map((item, index) => (
          <div class="tool-item">
            <span class="tool-number">{index + 1}</span>
            <span class="tool-text">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 赚钱方法详解 -->
  <section id="methods" class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">💰 核心方法</span>
        <h2 class="section-title">{toolData.name}赚钱的{toolData.methods.length}种方式</h2>
        <p class="section-description">每种方法都有详细的操作步骤和真实收入数据</p>
      </div>
      
      <div class="methods-grid">
        {toolData.methods.map((method, index) => (
          <div class="method-card">
            <div class="method-header">
              <span class="method-number">方法 {index + 1}</span>
              <span class="method-income">{method.income}</span>
            </div>
            <h3 class="method-title">{method.title}</h3>
            <p class="method-desc">{method.desc}</p>
            
            <div class="method-steps">
              <h4>操作步骤：</h4>
              <ol>
                {method.steps.map(step => (
                  <li>{step}</li>
                ))}
              </ol>
            </div>
            
            <div class="method-tip">
              <span class="tip-icon">💡</span>
              <span>{method.tip}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 接单平台 -->
  <section id="platforms" class="section section-dark">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">📱 接单渠道</span>
        <h2 class="section-title">去哪里接单？</h2>
        <p class="section-description">推荐{toolData.platforms.length}个最靠谱的接单平台</p>
      </div>
      
      <div class="platforms-grid">
        {toolData.platforms.map((platform) => (
          <a href={platform.link} class="platform-card">
            <h3 class="platform-name">{platform.name}</h3>
            <p class="platform-desc">{platform.desc}</p>
            <span class="platform-action">去接单 →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 经验技巧 -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">⭐ 经验分享</span>
        <h2 class="section-title">老司机的经验总结</h2>
      </div>
      <div class="tips-grid">
        {toolData.tips.map((tip) => (
          <div class="tip-card">
            <span class="tip-icon-large">✅</span>
            <p>{tip}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">❓ 常见问题</span>
        <h2 class="section-title">新手必看FAQ</h2>
      </div>
      <div class="faq-list">
        {toolData.faq.map((item) => (
          <div class="faq-item">
            <h4 class="faq-question">Q: {item.q}</h4>
            <p class="faq-answer">A: {item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta">
    <div class="container">
      <div class="cta-content">
        <span class="cta-badge">🎁 限时福利</span>
        <h2 class="cta-title">准备好用{toolData.name}赚钱了吗？</h2>
        <p class="cta-description">
          现在行动，比别人更快一步！<br>
          前100名用户可获得专属赚钱工具包
        </p>
        <div class="cta-actions">
          <a href={toolData.url || '#'} target="_blank" class="btn btn-urgent btn-large">🔥 立即免费使用{toolData.name}</a>
          <a href="/" class="btn btn-primary btn-large">💎 查看更多赚钱工具</a>
          <a href="#" class="btn btn-secondary btn-large" style="background: rgba(255,255,255,0.2); color: white;">📱 加入赚钱交流群</a>
        </div>
        <div class="cta-urgency">
          <span>⏰ 已有 <strong>2,847</strong> 人通过{toolData.name}实现收入增长</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <span class="logo-icon">💰</span>
          <span class="logo-text">AIToolGuide</span>
          <span class="logo-tag">赚钱版</span>
          <p class="footer-description">专注AI工具变现，让每个人都能用AI创造收入。</p>
        </div>
        <div class="footer-links">
          <div class="footer-column">
            <h4>赚钱工具</h4>
            <a href="/tool/chatgpt">ChatGPT赚钱</a>
            <a href="/tool/midjourney">Midjourney赚钱</a>
            <a href="/tool/notion">Notion AI赚钱</a>
          </div>
          <div class="footer-column">
            <h4>变现攻略</h4>
            <a href="#">新手入门</a>
            <a href="#">进阶技巧</a>
            <a href="#">接单平台</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 AIToolGuide.tech 赚钱版. All rights reserved.</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* 复用首页样式 */
  .urgency-banner {
    background: linear-gradient(90deg, #fef3c7, #fee2e2);
    padding: 10px;
    text-align: center;
    font-weight: 600;
    color: #92400e;
    font-size: 0.9rem;
  }
  
  .header {
    position: fixed;
    top: 32px;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    z-index: 1000;
    border-bottom: 1px solid var(--border);
  }
  
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 1.5rem;
  }
  
  .logo-icon {
    font-size: 1.8rem;
  }
  
  .logo-text {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .logo-tag {
    font-size: 0.7rem;
    background: linear-gradient(135deg, #f59e0b, #ef4444);
    color: white;
    padding: 4px 10px;
    border-radius: 12px;
    font-weight: 700;
  }
  
  .nav-links {
    display: flex;
    gap: 30px;
  }
  
  .nav-links a {
    font-weight: 600;
    color: var(--gray);
    transition: color 0.3s;
  }
  
  .nav-links a:hover {
    color: var(--primary);
  }
  
  .btn-small {
    padding: 10px 20px;
    font-size: 0.9rem;
  }
  
  /* Hero */
  .hero {
    padding: 140px 0 80px;
    text-align: center;
  }
  
  .tool-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 24px;
    border-radius: 30px;
    font-weight: 700;
    margin-bottom: 24px;
  }
  
  .tool-icon-large {
    font-size: 2rem;
  }
  
  .hero-title {
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1.3;
    margin-bottom: 20px;
    color: var(--dark);
  }
  
  .hero-description {
    font-size: 1.2rem;
    color: var(--gray);
    max-width: 700px;
    margin: 0 auto 40px;
  }
  
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  
  .stat-card {
    background: white;
    padding: 24px 40px;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    text-align: center;
  }
  
  .stat-value {
    display: block;
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 8px;
  }
  
  .stat-label {
    color: var(--gray);
    font-size: 0.9rem;
  }
  
  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  /* Sections */
  .section {
    padding: 80px 0;
  }
  
  .section-light {
    background: #f8fafc;
  }
  
  .section-dark {
    background: linear-gradient(135deg, #0f172a, #1e293b);
    color: white;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 50px;
  }
  
  .section-badge {
    display: inline-block;
