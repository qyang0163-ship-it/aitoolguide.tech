        income: '￥100-500/篇',
        tip: '注意：只做辅助，不涉及学术造假'
      },
      {
        title: '短视频脚本创作',
        desc: '为抖音、快手创作者写脚本',
        steps: ['找到短视频创作者群体', '提供脚本试写', '用ChatGPT批量生成创意', '建立长期合作关系'],
