    <div class="container">
      <div class="hero-content">
        <div class="hero-badge-group">
          <span class="hero-badge">💰 {toolData.category}</span>
          <span class="money-badge">预期收入：{toolData.income}</span>
        </div>
        <h1 class="hero-title">{toolData.headline}</h1>
        <p class="hero-description">{toolData.description}</p>
        
        <div class="hero-meta">
          <div class="meta-item">
            <span class="meta-label">上手难度</span>
            <span class="meta-value">{toolData.difficulty}</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">首单时间</span>
            <span class="meta-value">{toolData.timeToFirstIncome}</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">赚钱方法</span>
            <span class="meta-value">{toolData.methods.length}种</span>
          </div>
        </div>

        <div class="hero-actions">
          <a href="#methods" class="btn btn-urgent btn-large">🔥 立即学习变现方法</a>
          <a href="#tools" class="btn btn-primary btn-large">🚀 免费使用工具</a>
          <a href="#community" class="btn btn-secondary btn-large">📱 加入赚钱交流群</a>
