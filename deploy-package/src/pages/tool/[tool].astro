const { tool } = Astro.params;
const toolData = toolDetails[tool] || toolDetails['chatgpt'];
---

<Layout title={`${toolData.name}怎么赚钱？2026年实测变现攻略 - AI工具赚钱指南`}>
  <!-- 顶部紧迫感横幅 -->
