    </div>
  </section>

  <!-- 所需工具 -->
  <section class="tools-needed">
    <div class="container">
      <h2 class="section-title">你需要准备什么？</h2>
      <div class="tools-grid">
        {toolData.tools.map((item, index) => (
          <div class="tool-item">
            <span class="tool-number">{index + 1}</span>
            <span class="tool-text">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 赚钱方法详解 -->
  <section id="methods" class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">💡 实操方法</span>
        <h2 class="section-title">{toolData.methods.length}种变现方法详解</h2>
        <p class="section-description">每种方法都有详细步骤和真实收入数据</p>
      </div>
      
      <div class="methods-list">
        {toolData.methods.map((method, index) => (
          <div class="method-card">
            <div class="method-header">
              <div class="method-number">{index + 1}</div>
              <div class="method-info">
                <h3 class="method-title">{method.title}</h3>
                <span class="method-income">{method.income}</span>
              </div>
            </div>
            <p class="method-desc">{method.desc}</p>
            
            <div class="method-steps">
              <h4>操作步骤：</h4>
              <ol>
                {method.steps.map((step) => (
                  <li>{step}</li>
                ))}
              </ol>
            </div>
            
            <div class="method-tip">
              <span class="tip-icon">💡</span>
              <span class="tip-text">{method.tip}</span>
            </div>
