            <p class="faq-answer">A: {item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 底部CTA -->
  <section id="start" class="cta">
    <div class="container">
      <div class="cta-content">
        <span class="cta-badge">🎁 限时福利</span>
        <h2 class="cta-title">准备好开始赚钱了吗？</h2>
        <p class="cta-description">
          现在行动，你也可以像其他人一样月入过万！<br>
          现在加入即可获得：《AI赚钱工具包》+ 独家接单渠道
        </p>
        
        <div class="cta-actions">
          <a href="#" class="btn btn-urgent btn-large">🔥 立即开始赚钱（免费）</a>
          <a href="#" class="btn btn-primary btn-large">💎 领取工具包</a>
          <a href="#" class="btn btn-secondary btn-large" style="background: rgba(255,255,255,0.2); color: white; border-color: rgba(255,255,255,0.3);">
            📱 加入赚钱交流群
          </a>
        </div>
        
        <div class="cta-urgency">
          <span>⏰ 已有 <strong>12,847</strong> 人加入 | 剩余名额 <strong>153</strong> 个</span>
        </div>
