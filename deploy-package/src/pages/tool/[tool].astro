  <!-- Header -->
  <header class="header">
    <div class="container">
      <nav class="nav">
        <a href="/" class="logo">
          <span class="logo-icon">💰</span>
          <span class="logo-text">AIToolGuide</span>
          <span class="logo-tag">赚钱版</span>
        </a>
        <div class="nav-links">
          <a href="/">首页</a>
