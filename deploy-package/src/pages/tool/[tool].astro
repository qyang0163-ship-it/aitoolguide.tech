    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <span class="logo-icon">💰</span>
          <span class="logo-text">AIToolGuide</span>
          <span class="logo-tag">赚钱版</span>
          <p class="footer-description">专注AI工具变现，让每个人都能用AI创造收入。</p>
        </div>
        <div class="footer-links">
          <div class="footer-column">
            <h4>赚钱工具</h4>
            <a href="/">AI写作工具</a>
