          </div>
          <div class="footer-column">
            <h4>变现攻略</h4>
            <a href="/">新手入门</a>
            <a href="/">进阶技巧</a>
            <a href="/">接单平台</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 ai2424.com 赚钱版. All rights reserved.</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .header {
    position: fixed;
    top: 32px;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    z-index: 1000;
    border-bottom: 1px solid var(--border);
  }
  
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 1.5rem;
  }
  
  .logo-icon { font-size: 1.8rem; }
  
  .logo-text {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
