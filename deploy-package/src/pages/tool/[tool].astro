    </div>
  </section>

  <!-- 经验技巧 -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">⭐ 经验分享</span>
        <h2 class="section-title">高手都在用的技巧</h2>
        <p class="section-description">这些技巧能让你事半功倍，收入翻倍</p>
      </div>
      
      <div class="tips-grid">
        {toolData.tips.map((tip) => (
          <div class="tip-card">
            <span class="tip-icon">✓</span>
            <p class="tip-text">{tip}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">❓ 常见问题</span>
