  .btn-small { padding: 10px 20px; font-size: 0.9rem; }
  
  .hero {
    padding: 140px 0 80px;
    background: linear-gradient(180deg, #fef3c7 0%, #fff 50%, #f0f9ff 100%);
    text-align: center;
  }
  
  .hero-badge-group {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  
  .hero-badge {
    display: inline-block;
    padding: 10px 20px;
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 20px;
  }
  
  .hero-title {
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1.3;
    margin-bottom: 24px;
    color: var(--dark);
